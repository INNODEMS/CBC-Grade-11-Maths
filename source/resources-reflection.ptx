<!-- Added to lesson plans at the end for teacher relfection-->
<axiom component="lesson-plan">
    <title>Teacher Reflection</title>
    <p>
        Complete this after the lesson
        <ol markers="1.">
            <li>
                <p>
                    What went well?
                </p>
            </li>
            <li>
                <p>
                    What would I change?
                </p>
            </li>
            <li>
                <p>
                    Learner Understanding: What did the exit tickets reveal about Learner learning?
                </p>
            </li>
            <li>
                <p>
                    Next Steps: Based on the assessment data, what is the plan for the next lesson?
                </p>
            </li>
        </ol>
    </p>
</axiom>