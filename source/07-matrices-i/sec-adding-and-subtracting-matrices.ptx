    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->

    <exercises>
     <exercise xml:id="PRECALC-q5g1X2Lgdo" original="PRECALC/modules/m49433/index.cnxml" license="CC-BY-4.0">
            <statement>
                <p>Add matrix <m>A</m> and matrix <m>B.</m>
                </p>
                <p>
                    <me>A=\begin{bmatrix} 2 &amp; 6 \\ 1 &amp; 0 \\ 1 &amp; −3 \end{bmatrix}\text{ and }B=\begin{bmatrix} 3 &amp; −2 \\ 1 &amp; 5 \\ −4 &amp; 3 \end{bmatrix}</me>
                </p>
            </statement>
            <solution>
                <p>
                    <md>
                        <mrow> A+B &amp; = \begin{bmatrix} 2 &amp; 6 \\ 1 &amp; 0 \\ 1 &amp; −3 \end{bmatrix} + \begin{bmatrix} 3 &amp; −2 \\ 1 &amp; 5 \\ −4 &amp; 3 \end{bmatrix} </mrow>
                        <mrow> &amp; = \begin{bmatrix} 2+3 &amp; 6+(−2) \\ 1+1 &amp; 0+5 \\ 1+(−4) &amp; −3+3 \end{bmatrix} </mrow>
                        <mrow> &amp; = \begin{bmatrix} 5 &amp; 4 \\ 2 &amp; 5 \\ −3 &amp; 0 \end{bmatrix} </mrow>
                    </md>
                </p>
            </solution>
        </exercise>
     <exercise xml:id="PRECALC-TQUChsY7ZQ" original="PRECALC/modules/m49433/index.cnxml" license="CC-BY-4.0">
      <statement>
        <p>Given matrix <m>B,</m> find <m>2B</m> where</p>
        <p>
          <me>B=\begin{bmatrix} 4 &amp; 1 \\ 3 &amp; 2 \end{bmatrix}</me>
        </p>
      </statement>
      <hint>
        <p>
            Think of <m>2B</m> as <m>B + B</m>
        </p>
      </hint>
      <solution>
        <p>
          <m>2B=\begin{bmatrix} 8 &amp; 2 \\ 6 &amp; 4 \end{bmatrix}</m>
        </p>
      </solution>
    </exercise> 
    </exercises>

