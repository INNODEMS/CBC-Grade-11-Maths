    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->

    <exercises>
        <exercise>
            <statement>
                <p>Given the formula for the area of a trapezoid <m>A = \frac{1}{2}(a + b)h</m>:</p>
                <ol>
                    <li>Make <m>h</m> the subject of the formula.</li>
                    <li>Find <m>h</m> when <m>A = 30</m>, <m>a = 4</m>, and <m>b = 6</m>.</li>
                </ol>
            </statement>
            <answer>
                <p><strong>(a)</strong> <me>h = \frac{2A}{a + b}</me></p>
                <p><strong>(b)</strong> <me>h = \frac{2(30)}{4 + 6} = \frac{60}{10} = 6</me></p>
            </answer>
        </exercise>

        <exercise>
            <statement>
                <p>Given the formula for simple interest <m>I = \frac{PRT}{100}</m>:</p>
                <ol>
                    <li>Make <m>R</m> the subject of the formula.</li>
                    <li>Find <m>R</m> when <m>I = 200</m>, <m>P = 1000</m>, and <m>T = 4</m>.</li>
                </ol>
            </statement>
            <answer>
                <p><strong>(a)</strong> <me>R = \frac{100I}{PT}</me></p>
                <p><strong>(b)</strong> <me>R = \frac{100(200)}{1000 \times 4} = \frac{20000}{4000} = 5</me></p>
            </answer>
        </exercise>

        <exercise>
            <statement>
                <p>Given the equation for a straight line <m>3y + 2x = 12</m>:</p>
                <ol>
                    <li>Make <m>y</m> the subject of the formula.</li>
                    <li>Find <m>y</m> when <m>x = 3</m>.</li>
                </ol>
            </statement>
            <answer>
                <p><strong>(a)</strong> <me>y = \frac{12 - 2x}{3}</me></p>
                <p><strong>(b)</strong> <me>y = \frac{12 - 2(3)}{3} = \frac{12 - 6}{3} = \frac{6}{3} = 2</me></p>
            </answer>
        </exercise>

        <exercise>
            <statement>
                <p>Given the formula for the volume of a cylinder <m>V = \pi r^2 h</m>:</p>
                <ol>
                    <li>Make <m>h</m> the subject of the formula.</li>
                    <li>Find <m>h</m> when <m>V = 154</m>, <m>r = 7</m>, and <m>\pi \approx \frac{22}{7}</m>.</li>
                </ol>
            </statement>
            <answer>
                <p><strong>(a)</strong> <me>h = \frac{V}{\pi r^2}</me></p>
                <p><strong>(b)</strong> <me>h = \frac{154}{\frac{22}{7} \times 49} = \frac{154}{22 \times 7} = \frac{154}{154} = 1</me></p>
            </answer>
        </exercise>

        <exercise>
            <statement>
                <p>Given the relationship <m>F = \frac{9}{5}C + 32</m>:</p>
                <ol>
                    <li>Make <m>C</m> the subject of the formula.</li>
                    <li>Find <m>C</m> when <m>F = 68</m>.</li>
                </ol>
            </statement>
            <answer>
                <p><strong>(a)</strong> <me>C = \frac{5(F - 32)}{9}</me></p>
                <p><strong>(b)</strong> <me>C = \frac{5(68 - 32)}{9} = \frac{5(36)}{9} = 5 \times 4 = 20</me></p>
            </answer>
        </exercise>
    </exercises>

