    <!-- Add insight / key takeaway directly related to activity / learner experience -->

    <insight>
        <statement>
            <p><strong>Changing the Subject of a Formula</strong></p>
            <p>Changing the subject means rearranging a formula to make a chosen variable stand alone.</p>
            <p>Use inverse operations (add/subtract, multiply/divide, square/square root) to isolate the variable.</p>
            <p><em>Example:</em> <m>t = \frac{v - u}{a}</m></p>
            <p>Apply the same operation to both sides of the equation.</p>
            <p>This helps in solving equations and expressing formulas in different ways.</p>
        </statement>
    </insight>

    <!-- Add further instruction (not in a block) to develop ideas as needed -->

    <xi:include href="../lesson-plan-templates/example-intro.ptx" />

    <!-- Add at least 3 examples -->

    <example>
        
        <statement>
            <p>Given the formula <m>v^2 = u^2 + 2as</m>:</p>
            <ol>
                <li>Make <m>s</m> the subject of the formula.</li>
                <li>Find <m>s</m> when <m>v = 10</m>, <m>u = 2</m>, and <m>a = 6</m>.</li>
            </ol>
        </statement>
        <solution>
            <ol>
                <li>
                    <me>v^2 = u^2 + 2as</me>
                    <me>v^2 - u^2 = 2as</me>
                    <me>s = \frac{v^2 - u^2}{2a}</me>
                </li>
                <li>
                    <me>s = \frac{10^2 - 2^2}{2(6)}</me>
                    <me>s = \frac{100 - 4}{12}</me>
                    <me>s = \frac{96}{12}</me>
                    <me>s = 8</me>
                </li>
            </ol>
        </solution>
    </example>

    <example>
    
        <statement>
            <p>Given the formula <m>P = 2(l + w)</m>:</p>
            <ol>
                <li>Make <m>w</m> the subject of the formula.</li>
                <li>Find <m>w</m> when <m>P = 40</m> and <m>l = 12</m>.</li>
            </ol>
        </statement>
        <solution>
            <ol>
                <li>
                    <me>P = 2(l + w)</me>
                    <me>\frac{P}{2} = l + w</me>
                    <me>w = \frac{P}{2} - l</me>
                </li>
                <li>
                    <me>w = \frac{40}{2} - 12</me>
                    <me>w = 20 - 12</me>
                    <me>w = 8</me>
                </li>
            </ol>
        </solution>
    </example>

    <example>
        
        <statement>
            <p>Given the formula <m>y = mx + c</m>:</p>
            <ol>
                <li>Make <m>x</m> the subject of the formula.</li>
                <li>Find <m>x</m> when <m>y = 20</m>, <m>m = 3</m>, and <m>c = 5</m>.</li>
            </ol>
        </statement>
        <solution>
            <ol>
                <li>
                    <me>y = mx + c</me>
                    <me>y - c = mx</me>
                    <me>x = \frac{y - c}{m}</me>
                </li>
                <li>
                    <me>x = \frac{20 - 5}{3}</me>
                    <me>x = \frac{15}{3}</me>
                    <me>x = 5</me>
                </li>
            </ol>
        </solution>
    </example>

