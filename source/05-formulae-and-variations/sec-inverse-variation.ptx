    <title>Inverse Variation</title>
    <objectives component="outcomes">
        <introduction>
            <p>
            <dl>
                <li>
                    <title>Strand</title>
                    <p>
                        1.0 Numbers and Algebra
                    </p>
                </li>
                <li>
                    <title>Sub-Strand</title>
                    <p>
                        1.5 Formulae and Variations
                    </p>
                </li>
                <li>
                    <title>Specific Learning Outcomes</title> 
                    <p>
                            <ul>
                              <li>Solve direct and inverse variations from real life situations</li>
                              <li>Draw graphs of direct and inverse variations</li>
                            </ul>
                    </p>
                </li>
                <li component="lesson-plan">
                    <title>Grade Level</title>
                    <p>
                        11
                    </p>
                </li>
