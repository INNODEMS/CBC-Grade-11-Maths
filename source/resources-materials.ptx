<!-- Added to lesson plans at the end for teacher relfection-->
<axiom component="lesson-plan">
    <title>Materials &amp; Resources</title>
    <p>
        <ul>
            <li>
                <p>
                    <url href="https://innodems.github.io/CBC-Grade-10-Maths/">Teacher's Book</url>
                </p>
            </li>
            <li>
                <p>
                    <url href="https://innodems.github.io/CBC-Grade-10-Maths/student/">Learner's Book</url>
                </p>
            </li>
        </ul>
    </p>
    <p>
        <alert>Pre-Class Preparation List</alert>
        <ol markers="1.">
            <li>
                <p>
                    Test internet connectivity and access to the <url href="https://innodems.github.io/CBC-Grade-10-Maths/">online textbook</url>.
                </p>
            </li>
            <li>
                <p>
                    Ensure all Learner devices can access the digital textbook
                </p>
            </li>
            <li>
                <p>
                    Pre-load the checkpoint page on the teacher's display device
                </p>
            </li>
            <li>
                <p>
                    Have backup printed worksheets in case of technical issues
                </p>
            </li>
            <li>
                <p>
                    Arrange seating for pair work and station rotations.
                </p>
            </li>
        </ol>
    </p>
</axiom>