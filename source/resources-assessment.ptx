<!-- This text is added at near the end of plans to show the types of assessment -->
<axiom component="lesson-plan">
    <title>Assessment</title>

    <table>
        <title>Assessment methods</title>
        <tabular halign="left">
            <row header="yes" bottom="minor">
                <cell>Type</cell>
                <cell>Method</cell>
                <cell>Purpose</cell>
            </row>
            <row>
                <cell>Formative (During Lesson)</cell>
                <cell>
                    <line><alert>Observation:</alert> Teacher circulates during the anchor task, listening to group discussions.</line>
                    <line><alert>Questioning:</alert> Teacher asks probing questions to check for understanding.</line>
                    <line><alert>Exit Ticket:</alert> A short, independent task at the end of the lesson.</line>
                </cell>
                <cell>
                    <line>To monitor learner progress in real-time, provide immediate feedback, and adjust instruction as needed.</line>
                </cell>
            </row>
            <row>
                <cell>Summative (After Lesson)</cell>
                <cell>
                    <line>Homework assignment with more complex problems.</line>
                    <line>Future quiz/test questions.</line>
                </cell>
                <cell>
                    <line>To evaluate mastery of the learning objectives after instruction and practice.</line>
                </cell>
            </row>
        </tabular>
    </table>
</axiom>