<!-- This text is added at the start of each subsection to introduce the resources -->
<axiom component="lesson-plan">
    <title>Checkpoint Guide</title>
    <paragraphs>
    <title>Teacher's Role</title>
    </paragraphs>
    <p>
        <ul>
            <li>
                <p>
                    Pair Learners strategically so stronger learners can explain reasoning to peers.
                </p>
            </li>
            <li>
                <p>
                    Collect and review the exit tickets to gauge Learner understanding and identify any common misconceptions that need to be addressed in the next lesson.
                </p>
            </li>
        </ul>
    </p>
    <paragraphs>
        <title>Instructions to Give Leaners</title>
    </paragraphs>
    <p>
        <ol markers="1.">
            <li>
                <p>
                    Click <c>Show new example question</c> to load the problem
                </p>
            </li>
            <li>
                <p>
                    Solve the displayed question
                </p>
            </li>
            <li>
                <p>
                    Click <c>Submit</c> to check your answer
                </p>
            </li>
            <li>
                <p>
                    If incorrect, carefully read the feedback and analyse the error before trying a new question. The immediate feedback from checkpoint submissions allows Learners to identify and correct errors in real-time.
                </p>
            </li>
            <li>
                <p>
                    Complete at least 5 questions before rotating
                </p>
            </li>
        </ol>
    </p>
</axiom>