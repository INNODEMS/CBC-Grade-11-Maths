    <!-- Add STACK exercises if made -->

    <!-- Add static exercises -->
     <exercises>
        <exercise>
            <statement>
                <p>
                    Find the simple interest earned after <m>4</m> years on <m>\text{Ksh} \; 8,000</m> at an interest rate of <m> 5 \;\text{%}</m>.
                </p>
            </statement>
            <answer>
                <p> Ksh <m>1,600</m></p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    Find the simple interest earned after <m>2</m> years on <m>\text{Ksh} \; 70,000 </m> at an interest rate of <m> 4 \;\text{%}</m>.
                </p>
            </statement>
            <answer>
                <p>Ksh <m>5600</m></p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    Find the principal invested if <m>\text{Ksh}\; 4950 </m> interest was earned in <m>3</m> years at an interest rate of <m> 6 \;\text{%}</m>.
                </p>
            </statement>
            <answer>
                <p> Ksh <m>27,500</m></p>
            </answer>
        </exercise>
        <exercise>
            <statement>
                <p>
                    Sean's new car loan statement said he would pay <m>\text{Ksh} \; 486,625</m> in interest from an interest rate of <m>8.5 \;\text{%}</m>.  If sean borrowed <m>1,145,000</m> from the bank to but the car. After how long should the loan be payed back?
                </p>
            </statement>
            <answer>
                <p>
                    <m>5</m> years
                </p>
            </answer>
        </exercise>
     </exercises>


