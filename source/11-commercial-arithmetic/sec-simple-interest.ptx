    <!-- Add at least 3 examples -->

    <example>
        <statement>
            <p>
                Esther deposited Ksh <m>12,500</m> in her bank account where it will earn <m>4 </m> % interest. How much interest will Esther earn in <m>5</m> years?
            </p>
        </statement>
        <solution>
            <p>
                We are asked to find the Interest, <m>I.</m>
            </p>
            <p>
                <md>
                    <mrow> I = \amp \;?</mrow>
                    <mrow> P = \amp \;\text{Ksh}\; 12,500</mrow>
                    <mrow> R = \amp \;4 \;\text{%}</mrow>
                    <mrow> T = \amp \;5 \;\text{years}</mrow>
                </md>
                
            </p>
            <p>
                We now apply the formula to calculate the interest earned by Esther,
            </p>
            <p>
                <md>
                    <mrow> I = \amp \;\frac{P\times R \times T}{100}</mrow>
                    <mrow> = \amp \;\frac{12,500 \times 4 \times 5}{100}</mrow>
                    <mrow> = \amp\; \text{Ksh}\; 2,500</mrow>
                </md>
                
            </p>
            <p>
                In <m>5</m> years, Esther will earn an interest of Ksh <m>2,500</m>.
            </p>
        </solution>
    </example>
    <example>
        <statement>
            <p>
               Kelvin got Ksh <m>900,000</m> as graduation gifts and invested it in a <m>10</m> month certificate of deposit that earned <m> 2.1</m> % interest. How much interest did this investment earn? 
            </p>
        </statement>
        <solution>
            <p>
                We are asked to calculate the interest, <m>I</m>.
            </p>
            <p>
                <md>
                    <mrow> I = \amp \; ?</mrow>
                    <mrow> P = \amp \; \text{Ksh}\;900,000</mrow>
                    <mrow> R = \amp \; 2.1 \; \text{%}</mrow>
                    <mrow> T = \amp \; 10 \; \text{months}</mrow>
                </md>
                
            </p>
            <p>
                Apply the formula to calculate the interest Kelvin earned,
            </p>
            <p>
                <md>
                    <mrow> I = \amp\; \frac{P \times R \times T}{100} </mrow>
                    <mrow> = \amp \; \frac{900,000 \times 2.1 \times 10} {100 \times 12}</mrow>
                    <mrow> = \amp \; \text{Ksh}\; 15,750</mrow>
                </md>
                
            </p>
            <p>
                Kelvin's interest after <m>10</m> months is Ksh <m>15,750</m>.
            </p>
            <p>
                Notice that the time is given as <m>10</m> months hence we convert it into years by dividing it by <m>12</m> months.
            </p>
        </solution>
    </example>
    <example>
        <statement>
            <p>
                Loren lent his brother <m>\text{Ksh} \;300,000</m> to help him buy a car. In <m>4 \text{years }</m> his brother paid him back the <m>\text{Ksh}\;366,000 </m>. What was the rate of interest?
            </p>
        </statement>
        <solution>
            <p>
                Apply the Interest formula to calculate the interest rate
            </p>
            <p>
                <md>
                    <mrow> P = \amp \; \text{Ksh}\;300,000</mrow>
                    <mrow> R = \amp \; ?</mrow>
                    <mrow> T = \amp \; 4 \; \text{years}</mrow>
                    <mrow> \text{Amount} = \amp \; \text{Ksh}\;366,000 </mrow>
                </md>
                
            </p>
            <p>
                We calculate the interest paid by Loren, <m>I = \text{Amount} - P = \text{Ksh} \; 66,000</m>
            </p>
            <p>
                <m>I = \frac{P \times R \times T}{100}</m>
            </p>
            <p>
                <md>
                    <mrow> R =  \amp \; \frac{100 \times I}{P \times T}</mrow>
                    <mrow> = \amp \; \frac{100 \times 66,000}{300,000 \times 4}</mrow>
                    <mrow> = \amp \; 5.5\; \text{%}</mrow>
                </md>
            </p>
            <p>
                The rate of interest is <m>5.5\; \text{%}</m>
            </p>
        </solution>
    </example>

