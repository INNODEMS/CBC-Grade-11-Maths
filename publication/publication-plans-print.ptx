<?xml version="1.0" encoding="UTF-8"?>

<!-- This is the publication file for a newly generated PreTeXt book.     -->
<!-- By changing the values of attributes here, you can change how        -->
<!-- the output looks and functions.  For the complete documentation      -->
<!-- of publication-file options, see                                     -->
<!-- https://pretextbook.org/doc/guide/html/publisher-file-reference.html -->

<!-- Commented settings below illustrate some possible changes you can    -->
<!-- make from the default values.                                        -->

<publication>
  <common>
    <!-- Level at which are html files generated (chapter/section/etc): -->
      <chunking level="3" />

    <!-- Depth for table of contents.  0 means no TOC -->
      <tableofcontents level="4" />

    <!-- Visibility of exercise components where they first appear.          -->
    <!-- There are four components (statement/hint/answer/solution) for each -->
    <!-- of five exercise types (inline/divisional/worksheet/reading/        -->
    <!-- project).                                                           -->
      <!--<exercise-inline statement="yes" hint="yes" answer="no" solution="no" />-->
      <!--<exercise-divisional statement="yes" hint="yes" answer="no" solution="yes" />-->
      <!--<exercise-worksheet statement="yes" hint="yes" answer="no" solution="no" />-->
      <!--<exercise-reading statement="yes" hint="yes" answer="no" solution="no" />-->
      <!--<exercise-project statement="yes" hint="yes" answer="yes" solution="yes" />-->

    <!-- Style of fill-in-the-blanks: -->
      <!--<fillin textstyle="underline" mathstyle="shade" />-->

    <!-- You can set a watermark: -->
      <!-- <watermark scale="0.5">DRAFT</watermark> -->

    <!-- Mermaid diagram themes -->
      <!-- <mermaid theme="default" /> -->  

    <!-- QR code image: set path to an image to put in center of QR codes -->
      <!-- <qrcode image="image.png" /> -->
  </common>


  <!-- Set where external assets and generated assets will be   -->
  <!-- stored or created.  Directories are relative to the main -->
  <!-- source PreTeXt file                                      -->
  <source>
    <!-- Paths to folders containing external assets and generated assets -->
    <!-- relative to your main source file.                               -->
    <directories external="../assets" generated="../generated-assets" />

    <!-- Set which marked elements are included in this version: -->
    <!-- See
    https://pretextbook.org/doc/guide/html/publication-file-source.html#publication-file-source-version -->
    <!-- Current versions are "resources" and "teacher" -->
    <version include="resources teacher outcomes print lesson-plan"/>
    

  </source>

  <stack server="https://stackapi-1-43834256136.europe-west1.run.app"/>

  <numbering>
    <!-- the divisions element describes the numbering of divisions.  -->
    <!-- @part-structure should be "decorative" or "structural",      -->
    <!-- were the latter would restart numbering chapters within each -->
    <!-- part (this only matters if your book has parts).             -->
    <!-- The attribute @chapter-start give the number of the first    -->
    <!-- chapter.  @level says how deep (chapter->section->subsection)-->
    <!-- numbering should appear.                                     -->
    <!-- For use with a book organized by part, you can set the -->
    <!--  @part-structure to "decorative" or "structural" -->
      <!--<divisions part-structure="decorative" chapter-start="0" level="2"/>-->

    <!-- The next elements say how the levels deep to break up the    -->
    <!-- numbering of the respective elements. Can't be more than the -->
    <!-- @level on divisions above.                                   -->
      <!--<blocks level="2" />-->
      <!--<projects level="2" />-->
      <!--<equations level="2" />-->
      <!--<footnotes level="2" />-->
  </numbering>

  <!-- LaTeX specific options: set @print="yes" to get pdf set up   -->
  <!-- for printing; set @sides="two" if the printing would be two- -->
  <!-- sided.  @pageref="yes/no" controls whether page number are   -->
  <!-- included in cross-references                                 -->
  <!-- <latex> -->
  <!-- Replace the <latex> tag above with the one below to try these-->
    <latex
          print="no"
          sides="one"
          open-odd="no"
          font-size="10"
          pageref="no"
          draft="no"
      > 

    <!-- Control text justification and bottom page behavior. Add content intended for \geometry{} inside the <geometry> element. -->
    <page>
        <geometry>a4paper,total={16cm,25cm}</geometry>
    </page>

    <!-- The asymptote/@links set to "yes" would produce  -->
    <!-- links the html version of asymptote graphics.    -->
      <!--<asymptote links="no" />-->

    <!-- Covers: provide paths to pdfs for front and back covers: -->
      <!--<covers front="cover-front.pdf" back="cover-back.pdf" />-->
    <!-- Set @formatted to "no" to remove formatting on worksheets: -->
      <!--<worksheets formatted="yes" />-->
    <!-- Lesson plan PDF pagebreak insertions: script will replace
         the block between the START/END markers below. -->
    <!-- LESSON_PLAN_INSERTIONS_START -->
    <insertions pagebreaks="sec-real-numbers subsec-classification-of-numbers subsubsec-even-and-odd-numbers subsubsec-prime-and-composite-numbers subsubsec-rational-and-irrational-numbers subsec-reciprocals-of-numbers subsubsec-reciprocals-using-division subsubsec-reciprocals-using-tables-and-calculators subsubsec-using-reciprocals sec-indices-and-logarithms subsec-indices subsubsec-introduction-to-indices subsubsec-laws-of-indices subsubsec-zero-and-negative-indices subsubsec-indices-in-real-life subsec-logarithms subsubsec-introduction-to-logarithms subsubsec-finding-logarithms-using-tables-and-calculators subsubsec-antilogarithms subsubsec-logarithms-of-products-and-ratios subsubsec-using-logarithms-to-compute-products-and-ratios subsubsec-logarithms-of-powers-and-roots subsubsec-logarithms-in-real-life sec-quadratic-expressions-and-equations subsec-quadratic-expressions subsubsec-forming-quadratic-expressions-by-multiplying-1 subsubsec-forming-quadratic-expressions-by-multiplying-2 subsubsec-forming-quadratic-expressions-in-real-life subsec-quadratic-identities subsubsec-perfect-squares subsubsec-difference-of-squares subsubsec-quadratic-identities-in-numerical-cases subsec-factorising-quadratics subsubsec-factorising-monic-quadratics subsubsec-factorising-non-monic-quadratics subsec-quadratic-equations subsubsec-formation-of-quadratic-equations subsubsec-solving-quadratic-equations subsubsec-quadratic-equations-in-real-life sec-similarity-and-enlargement subsec-introduction-to-similarity subsec-enlargements-of-objects subsubsec-positive-enlargements subsubsec-negative-enlargements subsec-scale-factors subsubsec-area-scale-factors subsubsec-volume-scale-factors subsec-similarity-and-enlargement-in-real-life sec-reflection-and-congruence subsec-properties-of-symmetry-and-reflection subsec-reflecting-objects subsec-equations-of-mirror-lines subsec-congruence-in-triangles subsec-reflection-and-congruence-in-real-life sec-rotation subsec-properties-of-rotation subsec-rotating-objects subsec-rotational-symmetry subsubsec-rotational-symmetry-of-plane-figures subsubsec-rotational-symmetry-of-solids subsec-rotation-and-congruence subsec-rotation-in-real-life sec-trigonometry-1 subsec-tangents-of-acute-angles subsec-sines-and-cosines-of-acute-angles subsec-sines-and-cosines-of-complementary-angles subsec-trigonometric-ratios-of-special-angles subsubsec-special-angles-0-45-and-90-degrees subsubsec-special-angles-30-and-60-degrees subsec-trigonometry-using-tables-and-calculators subsec-angles-of-elevation-and-depression subsubsec-angles-of-elevation subsubsec-angles-of-depression subsec-trigonometry-in-real-life sec-area-of-polygons subsec-area-of-triangles subsubsec-using-two-sides-and-an-angle subsubsec-herons-formula subsec-area-of-quadrilaterals subsubsec-area-of-squares-and-rectangles subsubsec-area-of-parallelograms subsubsec-area-of-rhombuses subsubsec-area-of-trapeziums subsubsec-area-of-kites subsec-area-of-regular-polygons subsubsec-area-of-heptagons subsubsec-area-of-octagons subsubsec-area-of-nonagons subsubsec-area-of-decagons subsec-area-of-irregular-polygons subsec-area-of-polygons-in-real-life sec-area-of-a-part-of-a-circle subsec-area-of-an-annulus subsec-area-of-sectors subsec-area-of-annular-sectors subsec-area-of-segments subsec-area-of-common-regions-between-circles subsec-area-of-a-part-of-a-circle-in-real-life sec-surface-area subsec-surface-area-of-cubes-and-cuboids subsec-surface-area-of-prisms subsec-surface-area-of-cylinders subsec-surface-area-of-pyramids subsec-surface-area-of-cones subsec-surface-area-of-frustums subsec-surface-area-of-spheres subsec-surface-area-of-composite-solids subsec-surface-area-in-real-life sec-volume subsec-volume-of-cubes-and-cuboids subsec-volume-of-prisms subsec-volume-of-cylinders subsec-volume-of-pyramids subsec-volume-of-cones subsec-volume-of-frustums subsec-volume-of-spheres subsec-volume-of-composite-solids subsec-volume-in-real-life sec-vectors-1 subsec-vector-and-scalar-quantities subsec-representing-vectors subsubsec-representing-vectors-geometrically subsubsec-column-vectors subsubsec-position-vectors subsec-magnitudes-of-vectors subsec-midpoints-of-vectors subsec-manipulating-vectors subsubsec-adding-vectors subsubsec-multiplying-vectors-by-scalars subsubsec-translating-vectors subsubsec-equivalent-vectors subsec-vectors-in-real-life sec-linear-motion subsec-distance-and-displacement subsec-speed-and-velocity subsec-relative-speeds subsubsec-relative-speeds-of-objects-moving-in-the-same-direction subsubsec-relative-speeds-of-objects-moving-in-different-directions subsec-acceleration subsec-displacement-time-graphs subsec-velocity-time-graphs subsec-linear-motion-in-real-life sec-statistics-1 subsec-introduction-to-statistics subsubsec-sources-of-data subsubsec-methods-of-data-collection subsec-ungrouped-data subsubsec-frequency-distribution-tables subsubsec-mean subsubsec-median subsubsec-mode subsec-grouped-data subsubsec-frequency-distribution-tables-grouped subsubsec-mean-grouped subsubsec-median-grouped subsubsec-mode-grouped subsec-histograms-and-frequency-polygons subsec-interpretation-of-data subsec-statistics-in-real-life sec-probability-1 subsec-introduction-to-probability subsec-probability-spaces subsec-mutually-exclusive-events subsec-independent-events subsec-laws-of-probability subsubsec-addition-rule subsubsec-multiplication-rule subsec-probability-using-tree-diagrams subsec-probability-in-real-life" />
    <!-- LESSON_PLAN_INSERTIONS_END -->
  </latex>

  <html>
    <baseurl href="https://innodems.github.io/CBC-Grade-11-Maths"/>
  </html>

  <!-- To use WeBWorK, you need a server.  -->
    <!-- <webwork server="https://webwork-ptx.aimath.org" /> -->
    <!-- @course, @coursepassword, @user, and @userpassword can also be set. -->
    <!-- You can also set how tasks are revealed for webwork problems using the @task-reveal attribute on the above-->

</publication>
