                <m>sin(\frac{11π}{3})cos(\frac{-5π}{6})</m>
              </li>
              <li>
                <m>sin(\frac{3π}{4})cos(\frac{5π}{3})</m>
              </li>
              <li>
                <m>sin(-\frac{4π}{3})cos(\frac{π}{2})</m>
              </li>
              <li>
                <m>sin(\frac{-9π}{4})cos(\frac{-π}{6})</m>
              </li>
              <li>
                <m>sin(\frac{π}{6})cos(\frac{-π}{3})</m>
              </li>
              <li>
                <m>sin(\frac{7π}{4})cos(\frac{-2π}{3})</m>
              </li>
              <li>
                <m>cos(\frac{5π}{6})cos(\frac{2π}{3})</m>
              </li>
              <li>
                <m>cos(\frac{-π}{3})cos(\frac{π}{4})</m>
              </li>
              <li>
                <m>sin(\frac{-5π}{4})sin(\frac{11π}{6})</m>
              </li>
              <li>
                <m>sin(π)sin(\frac{π}{6})</m>
              </li>
            </ol>
          </statement>
          <solution>
            <ol marker="(a)" cols="2">
              <li/>
