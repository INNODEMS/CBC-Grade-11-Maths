          <statement>
            <ol marker="(a)" cols="2">
              <li>
                <m>f(x)=2tan(4x-32)</m>
              </li>
              <li>
                <m>h(x)=2sec(\frac{π}{4}(x+1))</m>
              </li>
              <li>
                <m>m(x)=6csc(\frac{π}{3}x+π)</m>
              </li>
            </ol>
          </statement>
          <solution>
            <ol marker="(a)" cols="2">
              <li/>
              <li>period: 8; horizontal shift: 1 unit to left</li>
              <li/>
            </ol>
          </solution>
        </exercise>
      </exercisegroup>
  
    <exercisegroup>
        <title>Algebraic</title>
        <introduction>
          <p>For the following exercises, evaluate the transformed functions.</p>
        </introduction>
        <exercise xml:id="PRECALC-lLi2U5rQdP-parts" original="PRECALC/modules/m49389/index.cnxml" license="CC-BY-4.0">
          <statement>
            <ol marker="(a)" cols="2">
              <li>If <m>tanx=−1.5,</m> find <m>tan(-x).</m>
              </li>
              <li>If <m>secx=2,</m> find <m>sec(-x).</m>
              </li>
              <li>If <m>cscx=−5,</m> find <m>csc(-x).</m>
              </li>
              <li>If <m>xsinx=2,</m> find <m>(-x)sin(-x).</m>
              </li>
            </ol>
          </statement>
          <solution>
            <ol marker="(a)" cols="2">
              <li>1.5</li>
              <li/>
              <li>5</li>
              <li/>
            </ol>
          </solution>
        </exercise>
      </exercisegroup>
  
    <exercisegroup>
