        <exercise xml:id="PRECALC-k8p2GVkkew" original="PRECALC/modules/m49389/index.cnxml" license="CC-BY-4.0">
          <statement>
            <image xml:id="PRECALC-AHimLSyjKR" original="PRECALC/modules/m49389/index.cnxml" license="CC-BY-4.0" source="PRECALC/CNX_Precalc_Figure_06_02_222.jpg" width="80%">
