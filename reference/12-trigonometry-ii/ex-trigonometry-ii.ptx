          <statement>
            <ol marker="(a)" cols="2">
              <li>
                <m>f(x)=tanx</m>
              </li>
              <li>
                <m>f(x)=secx</m>
              </li>
              <li>
                <m>f(x)=cscx</m>
              </li>
              <li>
                <m>f(x)=cotx</m>
              </li>
            </ol>
          </statement>
          <solution>
            <ol marker="(a)" cols="2">
              <li/>
              <li>IV</li>
              <li/>
              <li>III</li>
            </ol>
          </solution>
        </exercise>
      </exercisegroup>
  
    <exercisegroup>
        <title>Algebraic</title>
