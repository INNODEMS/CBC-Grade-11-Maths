    <exercise xml:id="PRECALC-UHck4kE9Md-parts" original="PRECALC/modules/m49405/index.cnxml" license="CC-BY-4.0">
        <statement>
          <ol marker="(a)" cols="2">
            <li>A parallelogram has sides of length 16 units and 10 units. The shorter diagonal is 12 units. Find the measure of the longer diagonal.</li>
            <li>The sides of a parallelogram are 11 feet and 17 feet. The longer diagonal is 22 feet. Find the length of the shorter diagonal.</li>
            <li>The sides of a parallelogram are 28 centimeters and 40 centimeters. The measure of the larger angle is 100°. Find the length of the shorter diagonal.</li>
          </ol>
        </statement>
        <solution>
          <ol marker="(a)" cols="2">
            <li/>
            <li>18.3</li>
            <li/>
          </ol>
        </solution>
      </exercise>
  
    <exercise xml:id="PRECALC-Nv1FyVXRDw" original="PRECALC/modules/m49405/index.cnxml" license="CC-BY-4.0">
        <statement>
          <p>A regular octagon is inscribed in a circle with a radius of 8 inches. (See <xref ref="PRECALC-dbgiN0mG7X"/>.) Find the perimeter of the octagon.</p>
          <figure xml:id="PRECALC-dbgiN0mG7X" original="PRECALC/modules/m49405/index.cnxml" license="CC-BY-4.0">
            <caption>An octagon inscribed in a circle.</caption>
            <image source="PRECALC/CNX_Precalc_Figure_08_02_221.jpg" width="80%"/>
          </figure>
        </statement>
        <solution>
          <p>48.98</p>
        </solution>
      </exercise>
  
