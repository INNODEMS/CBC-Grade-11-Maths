              <li/>
              <li>320°</li>
            </ol>
          </solution>
        </exercise>
      </exercisegroup>
  
    <exercisegroup>
        <title>Algebraic</title>
        <introduction>
          <p>For the following exercises, find the angle between 0 and <m>2π</m> in radians that is coterminal to the given angle.</p>
        </introduction>
        <exercise xml:id="PRECALC-2FzjONK4Ju-parts" original="PRECALC/modules/m49371/index.cnxml" license="CC-BY-4.0">
          <statement>
            <ol marker="(a)" cols="2">
              <li>
                <m>-\frac{π}{9}</m>
              </li>
              <li>
                <m>\frac{10π}{3}</m>
              </li>
              <li>
                <m>\frac{13π}{6}</m>
              </li>
              <li>
                <m>\frac{44π}{9}</m>
              </li>
            </ol>
          </statement>
          <solution>
            <ol marker="(a)" cols="2">
              <li/>
              <li>
                <m>\frac{4π}{3}</m>
              </li>
              <li/>
              <li>
                <m>\frac{8π}{9}</m>
