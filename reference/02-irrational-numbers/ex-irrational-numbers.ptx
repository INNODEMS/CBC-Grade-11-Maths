              </li>
              <li>
                <m>\sqrt[3]{\frac{7}{54}}</m>
              </li>
              <li>
                <m>\frac{3}{\sqrt[3]{3x^{2}}}</m>
              </li>
              <li>
                <m>\frac{1}{\sqrt[3]{13}}</m>
              </li>
              <li>
                <m>\sqrt[3]{\frac{3}{128}}</m>
              </li>
              <li>
                <m>\frac{3}{\sqrt[3]{6y^{2}}}</m>
              </li>
              <li>
                <m>\frac{1}{\sqrt[4]{7}}</m>
              </li>
              <li>
                <m>\sqrt[4]{\frac{5}{32}}</m>
              </li>
              <li>
                <m>\frac{4}{\sqrt[4]{4x^{2}}}</m>
              </li>
              <li>
                <m>\frac{1}{\sqrt[4]{4}}</m>
              </li>
              <li>
                <m>\sqrt[4]{\frac{9}{32}}</m>
              </li>
              <li>
                <m>\frac{6}{\sqrt[4]{9x^{3}}}</m>
              </li>
              <li>
                <m>\frac{1}{\sqrt[4]{9}}</m>
              </li>
              <li>
                <m>\sqrt[4]{\frac{25}{128}}</m>
              </li>
              <li>
                <m>\frac{6}{\sqrt[4]{27a}}</m>
              </li>
              <li>
                <m>\frac{1}{\sqrt[4]{8}}</m>
              </li>
              <li>
                <m>\sqrt[4]{\frac{27}{128}}</m>
              </li>
              <li>
                <m>\frac{16}{\sqrt[4]{64b^{2}}}</m>
              </li>
            </ol>
          </statement>
          <solution>
            <ol marker="(a)" cols="2">
              <li>
                <m>\frac{5\sqrt{6}}{3}</m>
              </li>
              <li>
                <m>\frac{2\sqrt{3}}{9}</m>
              </li>
              <li>
                <m>\frac{2\sqrt{5x}}{x}</m>
              </li>
              <li />
              <li />
              <li />
              <li>
                <m>\frac{6\sqrt{7}}{7}</m>
