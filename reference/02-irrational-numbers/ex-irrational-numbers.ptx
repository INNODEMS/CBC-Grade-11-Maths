            <li>
              <m>(4\sqrt{6})(\text{ − }\sqrt{18})</m>
            </li>
            <li>
              <m>(7\sqrt[3]{4})(−3\sqrt[3]{18})</m>
            </li>
            <li>
              <m>(4\sqrt{12x^{5}})(2\sqrt{6x^{3}})</m>
            </li>
            <li>
              <m>(\sqrt{29})^{2}</m>
            </li>
            <li>
              <m>(−4\sqrt{17})(−3\sqrt{17})</m>
            </li>
            <li>
              <m>(−4+\sqrt{17})(−3+\sqrt{17})</m>
            </li>
            <li>
              <m>(3\sqrt[4]{8a^{2}})(\sqrt[4]{12a^{3}})</m>
            </li>
            <li>
              <m>(6-3\sqrt{2})^{2}</m>
            </li>
            <li>
              <m>\sqrt{3}(4-3\sqrt{3})</m>
