    <exercise xml:id="PREALG-DX5abTkDRJ-parts" original="PREALG/modules/m81397/index.cnxml" license="CC-BY-4.0">
        <statement>
          <ol marker="(a)" cols="2">
            <li>
              <m>\frac{2}{3}\sqrt{27}+\frac{3}{4}\sqrt{48}</m>
