    <exercisegroup>
      <introduction>
        <p>
          <em>Estimate and Approximate Roots</em>
        </p>
        <p>In the following exercises, estimate each root between two consecutive whole numbers.</p>
      </introduction>
      <exercise xml:id="PREALG-DorijGSB4l-parts" original="PREALG/modules/m81444/index.cnxml" license="CC-BY-4.0">
        <statement>
          <ol marker="(a)" cols="2">
            <li>
              <m>\sqrt{70}</m>
            </li>
            <li>
              <m>\sqrt[3]{71}</m>
            </li>
            <li>
              <m>\sqrt{55}</m>
            </li>
            <li>
              <m>\sqrt[3]{119}</m>
            </li>
            <li>
              <m>\sqrt{200}</m>
            </li>
            <li>
              <m>\sqrt[3]{137}</m>
            </li>
            <li>
              <m>\sqrt{172}</m>
            </li>
            <li>
              <m>\sqrt[3]{200}</m>
            </li>
          </ol>
        </statement>
        <solution>
          <ol marker="(a)" cols="2">
            <li>
              <m>8 &lt; \sqrt{70} &lt; 9</m>
            </li>
            <li>
              <m>4 &lt; \sqrt[3]{71} &lt; 5</m>
            </li>
            <li />
            <li />
            <li>
              <m>14 &lt; \sqrt{200} &lt; 15</m>
            </li>
            <li>
              <m>5 &lt; \sqrt[3]{137} &lt; 6</m>
            </li>
            <li />
            <li />
          </ol>
        </solution>
      </exercise>
    </exercisegroup>
  
    <exercisegroup>
      <introduction>
        <p>In the following exercises, approximate each root and round to two decimal places.</p>
