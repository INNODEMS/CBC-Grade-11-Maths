              </li>
              <li>
                <m>\frac{\sqrt[3]{45}}{6}</m>
              </li>
              <li>
                <m>\frac{2\sqrt[3]{6a^{2}}}{3a}</m>
              </li>
              <li />
              <li />
              <li />
              <li>
                <m>\frac{\sqrt[3]{121}}{11}</m>
              </li>
