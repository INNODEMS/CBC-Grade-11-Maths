    <exercise xml:id="PREALG-koRSWCSZ74" original="PREALG/modules/m81397/index.cnxml" license="CC-BY-4.0">
      <statement>
        <ol marker="(a)">
          <li>
            <m>8\sqrt{2}-9\sqrt{2}</m>
          </li>
          <li>
            <m>4\sqrt[3]{x}+7\sqrt[3]{x}</m>
          </li>
          <li>
            <m>3\sqrt[4]{x}-5\sqrt[4]{y}.</m>
          </li>
        </ol>
      </statement>
      <solution>
        <ol marker="(a)">
          <li>
            <m>\text{ − }\sqrt{2}</m>
          </li>
          <li>
            <m>11\sqrt[3]{x}</m>
          </li>
          <li>
            <m>3\sqrt[4]{x}-5\sqrt[4]{y}</m>
          </li>
        </ol>
      </solution>
    </exercise>
  
    <exercise xml:id="PREALG-kmi71VY5RE" original="PREALG/modules/m81397/index.cnxml" license="CC-BY-4.0">
      <statement>
        <ol marker="(a)">
          <li>
            <m>5\sqrt{3}-9\sqrt{3}</m>
          </li>
          <li>
            <m>5\sqrt[3]{y}+3\sqrt[3]{y}</m>
          </li>
          <li>
            <m>5\sqrt[4]{m}-2\sqrt[3]{m}.</m>
          </li>
        </ol>
      </statement>
      <solution>
        <ol marker="(a)">
          <li>
            <m>−4\sqrt{3}</m>
          </li>
          <li>
            <m>8\sqrt[3]{y}</m>
          </li>
          <li>
            <m>5\sqrt[4]{m}-2\sqrt[3]{m}</m>
          </li>
        </ol>
      </solution>
    </exercise>
  
    <exercise xml:id="PREALG-Ac5UYwBaY7" original="PREALG/modules/m81397/index.cnxml" license="CC-BY-4.0">
      <statement>
        <ol marker="(a)">
          <li>
            <m>\sqrt{7x}-7\sqrt{7x}+4\sqrt{7x}</m>
          </li>
          <li>
            <m>4\sqrt[4]{5xy}+2\sqrt[4]{5xy}-7\sqrt[4]{5xy}.</m>
          </li>
        </ol>
      </statement>
      <solution>
        <ol marker="(a)">
          <li>
            <m>−2\sqrt{7x}</m>
          </li>
          <li>
