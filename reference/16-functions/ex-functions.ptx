              </li>
              <li>
                <m>f(x)=\frac{4x^{2}-10}{2x-4}</m>
              </li>
              <li>
                <m>f(x)=\frac{81x^{2}-18}{3x-2}</m>
              </li>
              <li>
                <m>f(x)=\frac{6x^{3}-5x}{3x^{2}+4}</m>
              </li>
              <li>
                <m>f(x)=\frac{x^{2}+5x+4}{x-1}</m>
              </li>
            </ol>
          </statement>
          <solution>
            <ol marker="(a)" cols="2">
              <li/>
              <li>
                <m>y=2x+4</m>
              </li>
              <li/>
              <li>
