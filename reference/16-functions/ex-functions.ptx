    <exercise xml:id="PRECALC-Cd0PiW3JVi-parts" original="PRECALC/modules/m49320/index.cnxml" license="CC-BY-4.0">
        <statement>
          <ol marker="(a)">
            <li>
              <m>f(x)=4-x,g(x)=-4x</m>
            </li>
            <li>
              <m>f(x)=3x+2,g(x)=5-6x</m>
            </li>
            <li>
              <m>f(x)=x^{2}+2x,g(x)=5x+1</m>
            </li>
            <li>
              <m>f(x)=\sqrt{x+2},g(x)=\frac{1}{x}</m>
            </li>
            <li>
              <m>f(x)=\frac{x+3}{2},g(x)=\sqrt{1-x}</m>
            </li>
          </ol>
        </statement>
        <solution>
          <ol marker="(a)">
            <li/>
            <li>
              <m>(f∘g)(x)=17-18x;(g∘f)(x)=-7-18x</m>
            </li>
            <li/>
            <li>
              <m>(f∘g)(x)=\sqrt{\frac{1}{x}+2};</m>
              <m>(g∘f)(x)=\frac{1}{\sqrt{x+2}}</m>
            </li>
            <li/>
          </ol>
        </solution>
      </exercise>
  
    <exercise xml:id="PRECALC-VtdDoyZ0Iw-parts" original="PRECALC/modules/m49320/index.cnxml" license="CC-BY-4.0">
        <statement>
          <ol marker="(a)">
            <li>
              <m>f(x)=\frac{x+1}{x+4},g(x)=\frac{1}{x}</m>
            </li>
            <li>
              <m>f(x)=\frac{1}{x+3},g(x)=\frac{1}{x-9}</m>
            </li>
            <li>
              <m>f(x)=\frac{1}{x},g(x)=\sqrt{x}</m>
            </li>
            <li>
              <m>f(x)=\frac{1}{x^{2}-1},g(x)=\sqrt{x+1}</m>
            </li>
          </ol>
        </statement>
        <solution>
          <ol marker="(a)">
            <li>
              <m>(f∘g)(x)=\frac{1+x}{1+4x},x \ne 0,x \ne -\frac{1}{4}</m>
            </li>
            <li/>
            <li>
              <m>(f∘g)(x)=\frac{1}{\sqrt{x}},x  0</m>
            </li>
            <li/>
          </ol>
        </solution>
      </exercise>
  
    <exercise xml:id="PRECALC-ZC3YR3w9sK-parts" original="PRECALC/modules/m49320/index.cnxml" license="CC-BY-4.0">
