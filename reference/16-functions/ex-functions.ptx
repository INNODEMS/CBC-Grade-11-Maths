        <statement>
          <p>Find an equation that could be represented by <xref ref="PRECALC-IGXemsfO1C" />.</p>
          <figure xml:id="PRECALC-IGXemsfO1C" original="PRECALC/modules/m49453/index.cnxml" license="CC-BY-4.0">
