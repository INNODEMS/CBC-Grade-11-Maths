              <description>
                               Graph of an even-degree polynomial.
                           </description>
            </image>
          </statement>
          <solution>
            <p>Yes. Number of turning points is 1. Least possible degree is 2.</p>
          </solution>
        </exercise>
        <exercise xml:id="PRECALC-0WYSwgeHGc" original="PRECALC/modules/m49346/index.cnxml" license="CC-BY-4.0">
