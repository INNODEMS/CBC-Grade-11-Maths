    <exercise xml:id="PRECALC-OYhLTmhsDl-parts" original="PRECALC/modules/m49320/index.cnxml" license="CC-BY-4.0">
        <statement>
          <ol marker="(a)">
            <li>
              <m>f(x)=-2x^{2}+3x</m>
            </li>
            <li>
              <m>f(x)=2|3x-1|</m>
            </li>
          </ol>
        </statement>
        <solution>
          <ol marker="(a)">
            <li>
              <m>f(-3)=-27;</m>
              <m>f(2)=-2;</m>
              <m>f(-a)=-2a^{2}-3a;</m>
              <m>-f(a)=2a^{2}-3a;</m>
              <m>f(a+h)=-2a^{2}+3a-4ah+3h-2h^{2}</m>
            </li>
            <li/>
          </ol>
        </solution>
      </exercise>
  
    <exercise xml:id="PRECALC-jVra4Kl76h-parts" original="PRECALC/modules/m49320/index.cnxml" license="CC-BY-4.0">
        <statement>
          <ol marker="(a)">
            <li>
              <m>f(x)=-3x+5</m>
            </li>
            <li>
              <m>f(x)=|x-3|</m>
            </li>
