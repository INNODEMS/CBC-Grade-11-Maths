              <m>\{(a,b),(c,d),(e,d)\}</m>
            </li>
            <li>
              <m>\{(5,2),(6,1),(6,2),(4,8)\}</m>
            </li>
            <li>
              <m>y^{2}+4=x,</m> for <m>x</m> the independent variable and <m>y</m> the dependent variable</li>
          </ol>
        </statement>
        <solution>
          <ol marker="(a)">
            <li>function</li>
            <li/>
            <li>not a function</li>
          </ol>
        </solution>
      </exercise>
  
