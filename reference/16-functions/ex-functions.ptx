        <exercise xml:id="PRECALC-sKvxpgDZ6u" original="PRECALC/modules/m49301/index.cnxml" license="CC-BY-4.0">
          <statement>
            <p>Given the following graph,</p>
            <ol marker="(a)">
              <li>Evaluate <m>f(0).</m>
              </li>
              <li>Solve for <m>f(x)=−3.</m>
              </li>
            </ol>
            <image xml:id="PRECALC-r6DmDFnjXu" original="PRECALC/modules/m49301/index.cnxml" license="CC-BY-4.0" source="PRECALC/CNX_Precalc_Figure_01_01_214-4087.jpg" width="80%">
              <description>
                               A Cartesian graph displays a blue W-shaped curve, typical of a quartic function. It has a local maximum at (0,1) and two local minima around (-2,-3) and (2,-3), extending upwards symmetrically.
                           </description>
            </image>
          </statement>
          <solution>
            <ol marker="(a)" cols="2">
              <li>
                <m>f(0)=1;</m>
              </li>
              <li>
                <m>f(x)=-3,x=-2</m> or <m>x=2</m>
              </li>
            </ol>
          </solution>
        </exercise>
        <exercise xml:id="PRECALC-gsoq8myDwj" original="PRECALC/modules/m49301/index.cnxml" license="CC-BY-4.0">
          <statement>
            <p>Given the following graph,</p>
            <ol marker="(a)">
              <li>Evaluate <m>f(4).</m>
              </li>
              <li>Solve for <m>f(x)=1.</m>
              </li>
            </ol>
            <image xml:id="PRECALC-PVZ4jhSNKj" original="PRECALC/modules/m49301/index.cnxml" license="CC-BY-4.0" source="PRECALC/CNX_Precalc_Figure_01_01_215-571f.jpg" width="80%">
              <description>
                               Graph of relation.
                           </description>
            </image>
          </statement>
        </exercise>
      </exercisegroup>
  
