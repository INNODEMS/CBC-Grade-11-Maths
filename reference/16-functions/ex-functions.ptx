              </li>
              <li>
                <m>g(x)=\frac{2x^{2}+7x-15}{3x^{2}-14x+15}</m>
              </li>
              <li>
                <m>a(x)=\frac{x^{2}+2x-3}{x^{2}-1}</m>
              </li>
