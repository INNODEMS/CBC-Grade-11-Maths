    <exercisegroup>
        <title>Graphical</title>
        <introduction>
          <p>For the following exercises, graph the system of inequalities. Label all points of intersection.</p>
        </introduction>
        <exercise xml:id="PRECALC-HtXTEER3WM-parts" original="PRECALC/modules/m49431/index.cnxml" license="CC-BY-4.0">
          <statement>
            <ol marker="(a)" cols="2">
              <li>
                <md>
                  <mrow>x^{2}+y &amp;lt; 1</mrow>
                  <mrow>y &amp;gt; 2x</mrow>
