    <exercisegroup>
      <introduction>
        <p>
          <em>Complete the Square of a Binomial Expression</em>
        </p>
        <p>In the following exercises, complete the square to make a perfect square trinomial. Then write the result as a binomial squared.</p>
      </introduction>
      <exercise xml:id="PREALG-gHDXw4C8aW-parts" original="PREALG/modules/m81401/index.cnxml" license="CC-BY-4.0">
        <statement>
          <ol marker="(a)" cols="2">
            <li>
              <m>m^{2}-24m</m>
            </li>
            <li>
              <m>x^{2}-11x</m>
            </li>
            <li>
              <m>p^{2}-\frac{1}{3}p</m>
            </li>
            <li>
              <m>n^{2}-16n</m>
            </li>
            <li>
              <m>y^{2}+15y</m>
            </li>
            <li>
              <m>q^{2}+\frac{3}{4}q</m>
            </li>
            <li>
              <m>p^{2}-22p</m>
            </li>
            <li>
              <m>y^{2}+5y</m>
            </li>
            <li>
              <m>m^{2}+\frac{2}{5}m</m>
            </li>
            <li>
              <m>q^{2}-6q</m>
            </li>
            <li>
              <m>x^{2}-7x</m>
            </li>
            <li>
              <m>n^{2}-\frac{2}{3}n</m>
            </li>
          </ol>
        </statement>
        <solution>
          <ol marker="(a)" cols="2">
            <li>
              <m>(m-12)^{2}</m>
            </li>
            <li>
              <m>(x-\frac{11}{2})^{2}</m>
            </li>
            <li>
              <m>(p-\frac{1}{6})^{2}</m>
            </li>
            <li />
            <li />
            <li />
            <li>
              <m>(p-11)^{2}</m>
            </li>
            <li>
              <m>(y+\frac{5}{2})^{2}</m>
            </li>
            <li>
              <m>(m+\frac{1}{5})^{2}</m>
            </li>
            <li />
            <li />
            <li />
          </ol>
        </solution>
      </exercise>
    </exercisegroup>
  
