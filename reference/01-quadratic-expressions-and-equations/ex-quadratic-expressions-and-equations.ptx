<!-- Borrowed from ORCCA section-the-quadratic-formula: The Quadratic Formula -->
  
  <exercises>
    <title>ORCCA exercises</title>
    <exercise xml:id="ORCCA-9eVVJ9BGV8" license="CC-BY-4.0"><statement><p>Webwork Omitted</p></statement></exercise>
    <exercise xml:id="ORCCA-teuKBJ5W0w" license="CC-BY-4.0">
        <statement>
          <p>
            What is the formula for the discriminant?
          </p>
        </statement>
      </exercise>
    <exercise xml:id="ORCCA-ecuqcqwfEQ" license="CC-BY-4.0">
        <statement>
          <p>
            Are there any kinds of quadratic equations where the quadratic formula is not the best
            tool to use?
          </p>
        </statement>
      </exercise>
    <exercise xml:id="ORCCA-S0KIQsQ2GO" license="CC-BY-4.0">
