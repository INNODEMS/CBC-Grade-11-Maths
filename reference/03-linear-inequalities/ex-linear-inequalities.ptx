            </li>
            <li>
              <m>5 &lt; 4x+1 &lt; 9</m>
            </li>
            <li>
              <m>−1 &lt; 3x+2 &lt; 8</m>
            </li>
            <li>
              <m>−8 &lt; 5x+2 \le −3</m>
            </li>
            <li>
              <m>−6 \le 4x-2 &lt; −2</m>
            </li>
