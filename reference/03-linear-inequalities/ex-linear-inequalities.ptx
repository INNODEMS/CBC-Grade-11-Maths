            </li>
            <li>
              <m>4(2x-1) \le 12</m> and<m>2(x+1) &lt; 4</m>
            </li>
            <li>
              <m>5(3x-2) \le 5</m> and<m>3(x+3) &lt; 3</m>
            </li>
            <li>
              <m>3(2x-3) &gt; 3</m> and<m>4(x+5) \ge 4</m>
            </li>
            <li>
              <m>−3(x+4) &lt; 0</m> and<m>−1(3x-1) \le 7</m>
            </li>
            <li>
              <m>\frac{1}{2}(3x-4) \le 1</m> and<m>\frac{1}{3}(x+6) \le 4</m>
            </li>
            <li>
              <m>\frac{3}{4}(x-8) \le 3</m> and<m>\frac{1}{5}(x-5) \le 3</m>
            </li>
            <li>
              <m>5x-2 \le 3x+4</m> and<m>3x-4 \ge 2x+1</m>
            </li>
            <li>
              <m>\frac{3}{4}x-5 \ge −2</m> and<m>−3(x+1) \ge 6</m>
            </li>
            <li>
              <m>\frac{2}{3}x-6 \ge −4</m> and<m>−4(x+2) \ge 0</m>
            </li>
            <li>
              <m>\frac{1}{2}(x-6)+2 &lt; −5</m> and<m>4-\frac{2}{3}x &lt; 6</m>
            </li>
            <li>
              <m>−5 \le 4x-1 &lt; 7</m>
            </li>
            <li>
