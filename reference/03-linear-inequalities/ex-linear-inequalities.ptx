<!-- Borrowed from ORCCA section-inequalities-graphically: Solving Inequalities Graphically -->
  
  <exercises>
    <title>ORCCA exercises</title>
    <exercise xml:id="ORCCA-NPy8ax9iYA" license="CC-BY-4.0">
        <statement>
          <p>
            The graph of the function <m>f</m> is above the graph of the function <m>g</m> between <m>x=6</m> and <m>x=9</m>. How many solutions does the inequality <m>f(x)\gt g(x)</m> have?
          </p>
        </statement>
      </exercise>
    <exercise xml:id="ORCCA-hGIeJ47v1G" license="CC-BY-4.0">
        <statement>
          <p>
            Can the solution set to the inequality <m>h(x)\gt k(x)</m> be the set of all real numbers?
            Why or why not?
          </p>
        </statement>
      </exercise>
    <exercise xml:id="ORCCA-lAopq0Qp3Z" license="CC-BY-4.0">
        <statement>
          <p>
            Can the solution set to the inequality <m>h(x)\gt k(x)</m> be the empty set
            (<ie />, the inequality has no solutions)?
            Why or why not?
          </p>
        </statement>
      </exercise>
    <exercise><statement><p>Webwork Omitted</p></statement></exercise>
    <exercise><statement><p>Webwork Omitted</p></statement></exercise>
    <exercisegroup xml:id="ORCCA-RIDE7hBsFJ" license="CC-BY-4.0">
        <title>Solving Inequalities Graphically</title>
        <exercise xml:id="ORCCA-PMIovYSMju" license="CC-BY-4.0">
          <statement>
            <p>
              Solve the equations and inequalities graphically.
              Use interval notation when applicable.
              <ol marker="a." cols="3" xml:id="ORCCA-vU6m1z86CD" license="CC-BY-4.0">
                <li xml:id="ORCCA-tyEjkbOCVE" license="CC-BY-4.0">
                  <p>
                    <m>\abs{\frac{2}{3}x+2}=4</m>
                  </p>
                </li>
                <li xml:id="ORCCA-ZjievqFD4P" license="CC-BY-4.0">
                  <p>
                    <m>\abs{\frac{2}{3}x+2}\gt 4</m>
                  </p>
                </li>
                <li xml:id="ORCCA-aqVljLRd6o" license="CC-BY-4.0">
                  <p>
                    <m>\abs{\frac{2}{3}x+2}\le 4</m>
                  </p>
                </li>
              </ol>
            </p>
          </statement>
          <solution>
            <p>
              <ol marker="a." xml:id="ORCCA-u98BVUc2Oi" license="CC-BY-4.0">
                <li xml:id="ORCCA-ZWxQNTDUUH" license="CC-BY-4.0">
                  <sidebyside widths="47% 47%" margins="0%">
                    <figure xml:id="ORCCA-7Kcathofx5" license="CC-BY-4.0">
                      <caption><m>y=\abs{\frac{2}{3}x+2}</m> and <m>y=4</m></caption>
                      <image>
                        <shortdescription>a plot with the graphs of y=abs(2/3x+2) and y=4;the graphs cross at the points (-9,4) and (3,4) with solid dots</shortdescription>
              <latex-image>
                  \begin{tikzpicture}
                      \begin{axis}[xmin=-12, xmax=6, ymin=-1, ymax=6,
                                  xtick={-10,-8,...,4}, ytick={1,2,...,5},
                                  minor xtick={-12,-11,...,6}, minor ytick={-1,0,...,6}]
                          \addplot[firstcurve] coordinates {(-12,6) (-3,0) (6,6)} node [pos=0.3, sloped, below]{$y=\abs{\frac{2}{3}x+2}$};
                          \addplot[secondcurve, domain=-12:6] {4} node[pos=0.45, above]{$y=4$};
                          \addplot[soliddot, color=fourthcolor] coordinates {(-9,4)};
                          \addplot[soliddot, color=fourthcolor] coordinates {(3,4)};
                      \end{axis}
                  \end{tikzpicture}
              </latex-image>
                      </image>
                    </figure>
                    <p>
                      To solve the equation <m>\abs{\frac{2}{3}x+2}=4</m>,
                      we will make a graph with both <m>y=\abs{\frac{2}{3}x+2}</m> and <m>y=4</m>.
                      The solution set is <m>\{-9,3\}</m>.
                    </p>
                  </sidebyside>
                </li>
                <li xml:id="ORCCA-PMDgKVJnan" license="CC-BY-4.0">
                  <sidebyside widths="47% 47%" margins="0%">
                    <figure xml:id="ORCCA-M4qJFj21pI" license="CC-BY-4.0">
                      <caption><m>y=\abs{\frac{2}{3}x+2}</m> and <m>y=4</m></caption>
                      <image>
                        <shortdescription>a plot with the graphs of y=abs(2/3x+2) and y=4;the graphs cross at the points (-9,4) and (3,4) with open dots and the V-shape above the line y=4 is highlighted</shortdescription>
              <latex-image>
                  \begin{tikzpicture}
                      \begin{axis}[xmin=-12, xmax=6, ymin=-1, ymax=6,
                                  xtick={-10,-8,...,4}, ytick={1,2,...,5},
                                  minor xtick={-12,-11,...,6},minor ytick={-1,0,...,6}]
                          \addplot[firstcurve] coordinates {(-12,6) (-3,0) (6,6)} node [pos=0.3, sloped, below]{$y=\abs{\frac{2}{3}x+2}$};
                          \addplot[secondcurve, domain=-12:6] {4} node[pos=0.45, above]{$y=4$};
                          \addplot[highlightcurve] coordinates{(-12,6) (-9,4)};
                          \addplot[highlightcurve] coordinates{(3,4) (6,6)};
                          \addplot[hollowdot, draw=fourthcolor] coordinates {(-9,4)};
                          \addplot[hollowdot, draw=fourthcolor] coordinates {(3,4)};
                      \end{axis}
                  \end{tikzpicture}
              </latex-image>
                      </image>
                    </figure>
                    <p>
                      To solve the inequality <m>\abs{\frac{2}{3}x+2}\gt 4</m>,
                      we will make a graph with both <m>y=\abs{\frac{2}{3}x+2}</m> and <m>y=4</m>.
                      We have highlighted the solution region that lies above <m>y=4</m>.
                      The solution set is <m>(-\infty,-9)\cup(3,\infty)</m>.
                    </p>
                  </sidebyside>
                </li>
                <li xml:id="ORCCA-cRILBikWIZ" license="CC-BY-4.0">
                  <sidebyside widths="47% 47%" margins="0%">
                    <figure xml:id="ORCCA-2o1Pg75p2A" license="CC-BY-4.0">
                      <caption><m>y=\abs{\frac{2}{3}x+2}</m> and <m>y=4</m></caption>
                      <image>
                        <shortdescription>a plot with the graphs of y=abs(2/3x+2) and y=4;the graphs cross at the points (-9,4) and (3,4) with solid dots and the V-shape below the line y=4 is highlighted</shortdescription>
              <latex-image>
                  \begin{tikzpicture}
                      \begin{axis}[xmin=-12, xmax=6, ymin=-1, ymax=6,
                                  xtick={-10,-8,...,4}, ytick={1,2,...,5},
                                  minor xtick={-12,-11,...,6},minor ytick={-1,0,...,6}]
                          \addplot[firstcurve] coordinates {(-12,6) (-3,0) (6,6)} node [pos=0.3, sloped, below]{$y=\abs{\frac{2}{3}x+2}$};
                          \addplot[secondcurve, domain=-12:6] {4} node[pos=0.45, above]{$y=4$};
                          \addplot[highlightcurve] coordinates{(-9,4) (-3,0) (3,4)};
                          \addplot[soliddot, color=fourthcolor] coordinates {(-9,4)};
                          \addplot[soliddot, color=fourthcolor] coordinates {(3,4)};
                      \end{axis}
                  \end{tikzpicture}
              </latex-image>
                      </image>
                    </figure>
                    <p>
                      To solve the inequality <m>\abs{\frac{2}{3}x+2}\le 4</m>,
                      we will make a graph with both <m>y=\abs{\frac{2}{3}x+2}</m> and <m>y=4</m>.
                      We have highlighted the solution region that lies below or on <m>y=4</m>.
                      The solution set is <m>(-9,3)</m>.
                    </p>
                  </sidebyside>
                </li>
              </ol>
            </p>
          </solution>
        </exercise>
        <exercise xml:id="ORCCA-brEI4eu2Dk" license="CC-BY-4.0">
          <statement>
            <p>
              Solve the equations and inequalities graphically.
              Use interval notation when applicable.
              <ol marker="a." cols="3" xml:id="ORCCA-1AzXwDtD1B" license="CC-BY-4.0">
                <li xml:id="ORCCA-71hhExtdKa" license="CC-BY-4.0">
                  <p>
                    <m>\abs{\frac{11-2x}{5}}=4</m>
                  </p>
                </li>
                <li xml:id="ORCCA-tYVX5l5Njf" license="CC-BY-4.0">
                  <p>
                    <m>\abs{\frac{11-2x}{5}}\gt 4</m>
                  </p>
                </li>
                <li xml:id="ORCCA-ABLPCn1L12" license="CC-BY-4.0">
                  <p>
                    <m>\abs{\frac{11-2x}{5}}\le 4</m>
                  </p>
                </li>
              </ol>
            </p>
          </statement>
          <solution>
            <p>
              <ol marker="a." xml:id="ORCCA-NGq01zH0JK" license="CC-BY-4.0">
                <li xml:id="ORCCA-jeYpIreCjb" license="CC-BY-4.0">
                  <sidebyside widths="47% 47%" margins="0%">
                    <figure xml:id="ORCCA-mUzmTnkHj1" license="CC-BY-4.0">
                      <caption><m>y=\abs{\frac{11-2x}{5}}</m> and <m>y=4</m></caption>
                      <image>
                        <shortdescription>a plot with the graphs of y=abs((11-2x)/5) and y=4;the graphs cross at the points (-4.5,4) and (15.5,4) with solid dots</shortdescription>
              <latex-image>
                  \begin{tikzpicture}
                      \begin{axis}[xmin=-12, xmax=20, ymin=-1, ymax=6,
                                  xtick={-8,-4,...,16}, ytick={1,2,...,5},
                                  minor xtick={-12,-10,...,20}, minor ytick={-1,0,...,6}]
                          \addplot[firstcurve] coordinates {(-9.5,6) (5.5,0) (20,5.8)} node [pos=0.7, sloped, below]{$y=\abs{\frac{2}{3}x+2}$};
                          \addplot[secondcurve, domain=-12:20] {4} node[pos=0.6, above]{$y=4$};
                          \addplot[soliddot, color=fourthcolor] coordinates {(-4.5,4)};
                          \addplot[soliddot, color=fourthcolor] coordinates {(15.5,4)};
                      \end{axis}
                  \end{tikzpicture}
              </latex-image>
                      </image>
                    </figure>
                    <p>
                      To solve the equation <m>\abs{\frac{11-2x}{5}}=4</m>,
                      we will make a graph with both <m>y=\abs{\frac{11-2x}{5}}</m> and <m>y=4</m>.
                      The solution set is <m>\{-4.5,15.5\}</m>.
                    </p>
                  </sidebyside>
                </li>
                <li xml:id="ORCCA-Ged94I1jTW" license="CC-BY-4.0">
                  <sidebyside widths="47% 47%" margins="0%">
                    <figure xml:id="ORCCA-XW1qok8hku" license="CC-BY-4.0">
                      <caption><m>y=\abs{\frac{11-2x}{5}}</m> and <m>y=4</m></caption>
                      <image>
                        <shortdescription>a plot with the graphs of y=abs((11-2x)/5) and y=4;the graphs cross at the points (-4.5,4) and (15.5,4) with open dots and the V-shape above the line y=4 is shaded</shortdescription>
              <latex-image>
                  \begin{tikzpicture}
                      \begin{axis}[xmin=-12, xmax=20, ymin=-1, ymax=6,
                                  xtick={-8,-4,...,16}, ytick={1,2,...,5},
                                  minor xtick={-12,-10,...,20}, minor ytick={-1,0,...,6}]
                          \addplot[firstcurve] coordinates {(-9.5,6) (5.5,0) (20,5.8)} node [pos=0.7, sloped, below]{$y=\abs{\frac{2}{3}x+2}$};
                          \addplot[secondcurve, domain=-12:20] {4} node[pos=0.6, above]{$y=4$};
                          \addplot[highlightcurve] coordinates {(-9.5,6) (-4.5,4)};
                          \addplot[highlightcurve] coordinates {(15.5,4) (20,5.8)};
                          \addplot[hollowdot, draw=fourthcolor] coordinates {(-4.5,4)};
                          \addplot[hollowdot, draw=fourthcolor] coordinates {(15.5,4)};
                      \end{axis}
                  \end{tikzpicture}
              </latex-image>
                      </image>
                    </figure>
                    <p>
                      To solve the inequality <m>\abs{\frac{11-2x}{5}}\gt 4</m>,
                      we will make a graph with both <m>y=\abs{\frac{11-2x}{5}}</m> and <m>y=4</m>.
                      We have highlighted the solution region that lies above <m>y=4</m>.
                      The solution set is <m>(-\infty,-4.5)\cup(15.5,\infty)</m>.
                    </p>
                  </sidebyside>
                </li>
                <li xml:id="ORCCA-ISAGzGtVYR" license="CC-BY-4.0">
                  <sidebyside widths="47% 47%" margins="0%">
                    <figure xml:id="ORCCA-7p0BmKffxz" license="CC-BY-4.0">
                      <caption><m>y=\abs{\frac{11-2x}{5}}</m> and <m>y=4</m></caption>
                      <image>
                        <shortdescription>a plot with the graphs of y=abs((11-2x)/5) and y=4;the graphs cross at the points (-4.5,4) and (15.5,4) with solid dots and the V-shape below the line y=4 is shaded</shortdescription>
              <latex-image>
                  \begin{tikzpicture}
                      \begin{axis}[xmin=-12, xmax=20, ymin=-1, ymax=6,
                                  xtick={-8,-4,...,16}, ytick={1,2,...,5},
                                  minor xtick={-12,-10,...,20}, minor ytick={-1,0,...,6}]
                          \addplot[firstcurve] coordinates {(-9.5,6) (5.5,0) (20,5.8)} node [pos=0.7, sloped, below]{$y=\abs{\frac{2}{3}x+2}$};
                          \addplot[secondcurve, domain=-12:20] {4} node[pos=0.6, above]{$y=4$};
                          \addplot[highlightcurve] coordinates {(-4.5,4) (5.5,0) (15.5,4)};
                          \addplot[soliddot, color=fourthcolor] coordinates {(-4.5,4)};
                          \addplot[soliddot, color=fourthcolor] coordinates {(15.5,4)};
                      \end{axis}
                  \end{tikzpicture}
              </latex-image>
                      </image>
                    </figure>
                    <p>
                      To solve the inequality <m>\abs{\frac{11-2x}{5}}\le 4</m>,
                      we will make a graph with both <m>y=\abs{\frac{11-2x}{5}}</m> and <m>y=4</m>.
                      We have highlighted the solution region that lies below or on <m>y=4</m>.
                      The solution set is <m>(-4.5,15.5)</m>.
                    </p>
                  </sidebyside>
                </li>
              </ol>
            </p>
          </solution>
        </exercise>
  
        <exercise xml:id="ORCCA-TVYVvpiiUL" license="CC-BY-4.0">
          <statement>
            <p>
              Solve the equations and inequalities graphically.
              Use interval notation when applicable.
              <ol marker="a." cols="3" xml:id="ORCCA-xtBNabS7YG" license="CC-BY-4.0">
                <li xml:id="ORCCA-ISsk55bTao" license="CC-BY-4.0">
                  <p>
                    <m>x^2-3=1</m>
                  </p>
                </li>
                <li xml:id="ORCCA-tHU1XG5hRE" license="CC-BY-4.0">
                  <p>
                    <m>x^2-3\gt1</m>
                  </p>
                </li>
                <li xml:id="ORCCA-bPF5SFdFgN" license="CC-BY-4.0">
                  <p>
                    <m>x^2-3\le1</m>
                  </p>
                </li>
              </ol>
            </p>
          </statement>
          <solution>
            <p>
              <ol marker="a." xml:id="ORCCA-ur3oxMLC8D" license="CC-BY-4.0">
                <li xml:id="ORCCA-HGLQPxAGYE" license="CC-BY-4.0">
                  <sidebyside widths="47% 47%" margins="0%">
                    <figure xml:id="ORCCA-IqmcQoYLoz" license="CC-BY-4.0">
                      <caption><m>y=x^2-3</m> and <m>y=1</m></caption>
                      <image>
                        <shortdescription>a plot with the graphs of y=x^2-3 and y=1;the graphs cross at the points (-2,1) and (2,1) with solid dots</shortdescription>
              <latex-image>
                  \begin{tikzpicture}
                      \begin{axis}[xmin=-5, xmax=5, ymin=-5, ymax=5,
                                  xtick={-4,-3,...,4}, ytick={-4,-3,...,4},
                                  minor xtick={-5,-4,...,5}, minor ytick={-5,-4,...,5},
                                  ]
                          \addplot[firstcurve,domain=-2.828:2.828] {x^2-3} node [pos=0.4, sloped, below]{$y=x^2-3$};
                          \addplot[secondcurve, domain=-5:5] {1} node[pos=0.1, above]{$y=1$};
                          \addplot[soliddot, color=fourthcolor] coordinates {(-2,1)};
                          \addplot[soliddot, color=fourthcolor] coordinates {(2,1)};
                      \end{axis}
                  \end{tikzpicture}
              </latex-image>
                      </image>
                    </figure>
                    <p>
                      To solve the equation <m>x^2-3=1</m>,
                      we will make a graph with both <m>y=x^2-3</m> and <m>y=1</m>.
                      The solution set is <m>\{-2,2\}</m>.
                    </p>
                  </sidebyside>
                </li>
                <li xml:id="ORCCA-PoOqsJeoyK" license="CC-BY-4.0">
                  <sidebyside widths="47% 47%" margins="0%">
                    <figure xml:id="ORCCA-64nG36kmhD" license="CC-BY-4.0">
                      <caption><m>y=x^2-3</m> and <m>y=1</m></caption>
                      <image>
                        <shortdescription>a plot with the graphs of y=x^2-3 and y=1;the graphs cross at the points (-2,1) and (2,1) with open dots and the U-shape above the line y=1 is highlighted</shortdescription>
              <latex-image>
                  \begin{tikzpicture}
                      \begin{axis}[xmin=-5, xmax=5, ymin=-5, ymax=5,
                                  xtick={-4,-3,...,4}, ytick={-4,-3,...,4},
                                  minor xtick={-5,-4,...,5}, minor ytick={-5,-4,...,5},
                                  ]
                          \addplot[firstcurve,domain=-2.828:2.828] {x^2-3} node [pos=0.4, sloped, below]{$y=x^2-3$};
                          \addplot[highlightcurve,domain=-2.828:-2] {x^2-3};
                          \addplot[highlightcurve,domain=2:2.828] {x^2-3};
                          \addplot[secondcurve, domain=-5:5] {1} node[pos=0.1, above]{$y=1$};
                          \addplot[hollowdot, draw=fourthcolor] coordinates {(-2,1)};
                          \addplot[hollowdot, draw=fourthcolor] coordinates {(2,1)};
                      \end{axis}
                  \end{tikzpicture}
              </latex-image>
                      </image>
                    </figure>
                    <p>
                      To solve the inequality <m>x^2-3\gt 1</m>,
                      we will make a graph with both <m>y=x^2-3</m> and <m>y=1</m>.
                      We have highlighted the solution region that lies above <m>y=1</m>.
                      The solution set is <m>(-\infty,-2)\cup(2,\infty)</m>.
                    </p>
                  </sidebyside>
                </li>
                <li xml:id="ORCCA-Yn3E7GNMZs" license="CC-BY-4.0">
                  <sidebyside widths="47% 47%" margins="0%">
                    <figure xml:id="ORCCA-3sBp45a32I" license="CC-BY-4.0">
                      <caption><m>y=x^2-3</m> and <m>y=1</m></caption>
                      <image>
                        <shortdescription>a plot with the graphs of y=x^2-3 and y=1;the graphs cross at the points (-2,1) and (2,1) with solid dots and the U-shape below the line y=1 is highlighted</shortdescription>
              <latex-image>
                  \begin{tikzpicture}
                      \begin{axis}[xmin=-5, xmax=5, ymin=-5, ymax=5,
                                  xtick={-4,-3,...,4}, ytick={-4,-3,...,4},
                                  minor xtick={-5,-4,...,5}, minor ytick={-5,-4,...,5},
                                  ]
                          \addplot[firstcurve,domain=-2.828:2.828] {x^2-3} node [pos=0.4, sloped, below]{$y=x^2-3$};
                          \addplot[highlightcurve,domain=-2:2] {x^2-3};
                          \addplot[secondcurve, domain=-5:5] {1} node[pos=0.1, above]{$y=1$};
                          \addplot[soliddot, color=fourthcolor] coordinates {(-2,1)};
                          \addplot[soliddot, color=fourthcolor] coordinates {(2,1)};
                      \end{axis}
                  \end{tikzpicture}
              </latex-image>
                      </image>
                    </figure>
                    <p>
                      To solve the inequality <m>x^2-3\le 1</m>,
                      we will make a graph with both <m>y=x^2-3</m> and <m>y=1</m>.
                      We have highlighted the solution region that lies below or on <m>y=1</m>.
                      The solution set is <m>[-2,2]</m>.
                    </p>
                  </sidebyside>
                </li>
              </ol>
            </p>
          </solution>
        </exercise>
  
        <exercise xml:id="ORCCA-lC8jnzx2cs" license="CC-BY-4.0">
          <statement>
            <p>
              Solve the equations and inequalities graphically.
              Use interval notation when applicable.
              <ol marker="a." cols="3" xml:id="ORCCA-IWXDvFSBve" license="CC-BY-4.0">
                <li xml:id="ORCCA-U0MT0wKVC9" license="CC-BY-4.0">
                  <p>
                    <m>x^2-x-3=x</m>
                  </p>
                </li>
                <li xml:id="ORCCA-JDp4t3Nakf" license="CC-BY-4.0">
                  <p>
                    <m>x^2-x-3\gt x</m>
                  </p>
                </li>
                <li xml:id="ORCCA-HbclyD9ZHt" license="CC-BY-4.0">
                  <p>
                    <m>x^2-x-3\le x</m>
                  </p>
                </li>
              </ol>
            </p>
          </statement>
          <solution>
            <p>
              <ol marker="a." xml:id="ORCCA-fWQ6Iwwjhy" license="CC-BY-4.0">
                <li xml:id="ORCCA-UCGml7gXqU" license="CC-BY-4.0">
                  <sidebyside widths="47% 47%" margins="0%">
                    <figure xml:id="ORCCA-gNXZ0gxruP" license="CC-BY-4.0">
                      <caption><m>y=x^2-x-3</m> and <m>y=x</m></caption>
                      <image>
                        <shortdescription>a plot with the graphs of y=x^2-x-3 and y= x;the graphs cross at the points (-1,1) and (3,3) with solid dots</shortdescription>
              <latex-image>
                  \begin{tikzpicture}
                      \begin{axis}[xmin=-5, xmax=5, ymin=-5, ymax=5,
                                  xtick={-4,-3,...,4}, ytick={-4,-3,...,4},
                                  minor xtick={-5,-4,...,5}, minor ytick={-5,-4,...,5},
                                  ]
                          \addplot[firstcurve,domain=-2.372:3.372] {x^2-x-3} node [pos=0.1, sloped, below]{$y=x^2-x-3$};
                          \addplot[secondcurve, domain=-5:5] {x} node[pos=0.1, above, sloped]{$y=x$};
                          \addplot[soliddot, color=fourthcolor] coordinates {(-1,-1)};
                          \addplot[soliddot, color=fourthcolor] coordinates {(3,3)};
                      \end{axis}
                  \end{tikzpicture}
              </latex-image>
                      </image>
                    </figure>
                    <p>
                      To solve the equation <m>x^2-x-3= x</m>,
                      we will make a graph with both <m>y=x^2-x-3</m> and <m>y=x</m>.
                      The solution set is <m>\{-1,3\}</m>.
                    </p>
                  </sidebyside>
                </li>
                <li xml:id="ORCCA-ghmtd9dd4j" license="CC-BY-4.0">
                  <sidebyside widths="47% 47%" margins="0%">
                    <figure xml:id="ORCCA-SqJ9qGZ1xP" license="CC-BY-4.0">
                      <caption><m>y=x^2-x-3</m> and <m>y=x</m></caption>
                      <image>
                        <shortdescription>a plot with the graphs of y=x^2-x-3 and y= x;the graphs cross at the points (-1,1) and (3,3) with open dots and the U-shape above the line y= x is highlighted</shortdescription>
              <latex-image>
                  \begin{tikzpicture}
                      \begin{axis}[xmin=-5, xmax=5, ymin=-5, ymax=5,
                                  xtick={-4,-3,...,4}, ytick={-4,-3,...,4},
                                  minor xtick={-5,-4,...,5}, minor ytick={-5,-4,...,5},
                                  ]
                          \addplot[firstcurve,domain=-2.372:3.372] {x^2-x-3} node [pos=0.1, sloped, below]{$y=x^2-x-3$};
                          \addplot[highlightcurve,domain=-2.372:-1] {x^2-x-3};
                          \addplot[highlightcurve,domain=3:3.372] {x^2-x-3};
                          \addplot[secondcurve, domain=-5:5] {x} node[pos=0.1, above, sloped]{$y=x$};
                          \addplot[hollowdot, draw=fourthcolor] coordinates {(-1,-1)};
                          \addplot[hollowdot, draw=fourthcolor] coordinates {(3,3)};
                      \end{axis}
                  \end{tikzpicture}
              </latex-image>
                      </image>
                    </figure>
                    <p>
                      To solve the inequality <m>x^2-x-3\gt  x</m>,
                      we will make a graph with both <m>y=x^2-x-3</m> and <m>y=x</m>.
                      We have highlighted the solution region that lies above <m>y=x</m>.
                      The solution set is <m>(-\infty,-1)\cup(3,\infty)</m>.
                    </p>
                  </sidebyside>
                </li>
                <li xml:id="ORCCA-gktguu58pP" license="CC-BY-4.0">
                  <sidebyside widths="47% 47%" margins="0%">
                    <figure xml:id="ORCCA-EkpTLcRiKE" license="CC-BY-4.0">
                      <caption><m>y=x^2-x-3</m> and <m>y=x</m></caption>
                      <image>
                        <shortdescription>a plot with the graphs of y=x^2-x-3 and y= x;the graphs cross at the points (-1,1) and (3,3) with solid dots and the U-shape below the line y= x is highlighted</shortdescription>
              <latex-image>
                  \begin{tikzpicture}
                      \begin{axis}[xmin=-5, xmax=5, ymin=-5, ymax=5,
                                  xtick={-4,-3,...,4}, ytick={-4,-3,...,4},
                                  minor xtick={-5,-4,...,5}, minor ytick={-5,-4,...,5},
                                  ]
                          \addplot[firstcurve,domain=-2.372:3.372] {x^2-x-3} node [pos=0.1, sloped, below]{$y=x^2-x-3$};
                          \addplot[highlightcurve,domain=-1:3] {x^2-x-3};
                          \addplot[secondcurve, domain=-5:5] {x} node[pos=0.1, above, sloped]{$y=x$};
                          \addplot[soliddot, color=fourthcolor] coordinates {(-1,-1)};
                          \addplot[soliddot, color=fourthcolor] coordinates {(3,3)};
                      \end{axis}
                  \end{tikzpicture}
              </latex-image>
                      </image>
                    </figure>
                    <p>
                      To solve the inequality <m>x^2-x-3\le  x</m>,
                      we will make a graph with both <m>y=x^2-x-3</m> and <m>y=x</m>.
                      We have highlighted the solution region that lies below or on <m>y=x</m>.
                      The solution set is <m>[-1,3]</m>.
                    </p>
                  </sidebyside>
                </li>
              </ol>
            </p>
          </solution>
        </exercise>
      </exercisegroup>
    <exercise><statement><p>Webwork Omitted</p></statement></exercise>
    <exercise><statement><p>Webwork Omitted</p></statement></exercise>
  </exercises>

