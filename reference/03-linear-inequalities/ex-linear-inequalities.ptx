            </li>
            <li>
              <m>x &lt; 2</m> or <m>x \ge 5</m>
            </li>
            <li>
              <m>x &lt; 0</m> or <m>x \ge 4</m>
            </li>
            <li>
              <m>2+3x \le 4</m> or<m>5-2x \le −1</m>
            </li>
            <li>
              <m>4-3x \le −2</m> or<m>2x-1 \le −5</m>
            </li>
            <li>
              <m>2(3x-1) &lt; 4</m> or<m>3x-5 &gt; 1</m>
            </li>
            <li>
              <m>3(2x-3) &lt; −5</m> or<m>4x-1 &gt; 3</m>
            </li>
            <li>
              <m>\frac{3}{4}x-2 &gt; 4</m> or <m>4(2-x) &gt; 0</m>
            </li>
            <li>
              <m>\frac{2}{3}x-3 &gt; 5</m> or <m>3(5-x) &gt; 6</m>
            </li>
            <li>
              <m>3x-2 &gt; 4</m> or <m>5x-3 \le 7</m>
            </li>
            <li>
              <m>2(x+3) \ge 0</m> or<m>3(x+4) \le 6</m>
            </li>
            <li>
              <m>\frac{1}{2}x-3 \le 4</m> or<m>\frac{1}{3}(x-6) \ge −2</m>
            </li>
            <li>
              <m>\frac{3}{4}x+2 \le −1</m> or<m>\frac{1}{2}(x+8) \ge −3</m>
            </li>
          </ol>
        </statement>
        <solution>
          <ol marker="(a)" cols="2">
            <li />
            <li />
            <li />
            <li />
            <li />
            <li />
            <li />
            <li />
            <li />
            <li />
            <li />
            <li />
            <li />
            <li />
          </ol>
        </solution>
