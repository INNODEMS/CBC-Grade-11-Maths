    <exercisegroup>
        <title>Technology</title>
        <introduction>
          <p>For the following exercises, use a graphing calculator to find the equation of an exponential function given the points on the curve.</p>
        </introduction>
        <exercise xml:id="PRECALC-wRENkjVvag-parts" original="PRECALC/modules/m49361/index.cnxml" license="CC-BY-4.0">
          <statement>
            <ol marker="(a)" cols="2">
              <li>
                <m>(0,3)</m> and <m>(3,375)</m>
              </li>
              <li>
                <m>(3,222.62)</m> and <m>(10,77.456)</m>
              </li>
              <li>
                <m>(20,29.495)</m> and <m>(150,730.89)</m>
              </li>
              <li>
                <m>(5,2.909)</m> and <m>(13,0.005)</m>
              </li>
              <li>
                <m>(11,310.035)</m> and <m>(25,356365.2)</m>
              </li>
            </ol>
          </statement>
          <solution>
            <ol marker="(a)" cols="2">
              <li>
                <m>y=3‚čÖ5^{x}</m>
              </li>
              <li />
              <li>
                <m>y‚Čą18‚čÖ1.025^{x}</m>
              </li>
