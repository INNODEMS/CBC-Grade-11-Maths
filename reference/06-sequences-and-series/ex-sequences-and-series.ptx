                <m>S_{6}</m> for the series <m>-2-10-50-250...</m>
              </li>
              <li>
                <m>S_{7}</m> for the series <m>0.4-2+10-50...</m>
              </li>
              <li>
                <m>∑_{k=1}^{9}2^{k-1}</m>
              </li>
              <li>
                <m>∑_{n=1}^{10}-2⋅(\frac{1}{2})^{n-1}</m>
              </li>
            </ol>
          </statement>
