    <exercisegroup>
        <title>Numeric</title>
        <introduction>
          <p>For the following exercises, use the formula for the sum of the first <m>n</m> terms of a geometric series to find the partial sum.</p>
        </introduction>
        <exercise xml:id="PRECALC-00Ka8aarNC-parts" original="PRECALC/modules/m49447/index.cnxml" license="CC-BY-4.0">
          <statement>
            <ol marker="(a)" cols="2">
