            <ol marker="(a)" cols="2">
              <li>
                <m>\{5,11,17,23,29,...\}</m>
              </li>
              <li>
                <m>\{0,\frac{1}{2},1,\frac{3}{2},2,...\}</m>
              </li>
            </ol>
          </statement>
          <solution>
            <ol marker="(a)" cols="2">
              <li />
              <li>The common difference is <m>\frac{1}{2}</m>
              </li>
            </ol>
          </solution>
        </exercise>
      </exercisegroup>
  
