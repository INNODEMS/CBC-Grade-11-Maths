        </introduction>
        <exercise xml:id="PRECALC-WKa6AxuFfS-parts" original="PRECALC/modules/m49445/index.cnxml" license="CC-BY-4.0">
          <statement>
            <ol marker="(a)" cols="2">
              <li>
                <m>a=\{3,5,7,...\}</m>
              </li>
              <li>
                <m>a=\{32,24,16,...\}</m>
              </li>
              <li>
                <m>a=\{-5\text{ , }95\text{ , }195\text{ , }...\}</m>
              </li>
              <li>
                <m>a=\{−17\text{ , }−217\text{ , }−417\text{ , }...\}</m>
              </li>
              <li>
                <m>a=\{1.8\text{ , }3.6\text{ , }5.4\text{ , }...\}</m>
              </li>
              <li>
                <m>a=\{−18.1,−16.2,−14.3,...\}</m>
              </li>
              <li>
                <m>a=\{15.8,18.5,21.2,...\}</m>
              </li>
              <li>
                <m>a=\{\frac{1}{3},-\frac{4}{3},−3\text{ , }...\}</m>
              </li>
              <li>
                <m>a=\{0,\frac{1}{3},\frac{2}{3},...\}</m>
              </li>
              <li>
                <m>a=\{-5,-\frac{10}{3},-\frac{5}{3},…\}</m>
              </li>
            </ol>
          </statement>
          <solution>
            <ol marker="(a)" cols="2">
              <li>
                <m>a_{n}=1+2n</m>
              </li>
              <li />
              <li>
                <m>a_{n}=-105+100n</m>
              </li>
              <li />
              <li>
                <m>a_{n}=1.8n</m>
              </li>
              <li />
              <li>
                <m>a_{n}=13.1+2.7n</m>
              </li>
              <li />
              <li>
                <m>a_{n}=\frac{1}{3}n-\frac{1}{3}</m>
              </li>
              <li />
            </ol>
          </solution>
        </exercise>
      </exercisegroup>
  
