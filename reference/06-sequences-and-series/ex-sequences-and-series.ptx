    <exercise xml:id="PRECALC-JGGYtsibTF" original="PRECALC/modules/m49445/index.cnxml" license="CC-BY-4.0">
      <title>Try It</title>
      <statement>
        <p>Write a recursive formula for the arithmetic sequence.</p>
        <p>
          <me>\{25\text{ , }\ 37\text{ , }\ 49\text{ , }\ 61\text{ , }\ \text{ … }\}</me>
        </p>
      </statement>
      <solution>
        <p>
          <md>
            <mrow>a_{1}&amp;=25</mrow>
            <mrow>a_{n}&amp;=a_{n-1}+12,\text{ for }n \ge 2</mrow>
          </md>
        </p>
      </solution>
    </exercise>
  
    <exercise xml:id="PRECALC-LBXok1UgID" original="PRECALC/modules/m49445/index.cnxml" license="CC-BY-4.0">
      <title>Try It</title>
      <statement>
        <p>Write an explicit formula for the following arithmetic sequence.</p>
        <p>
          <me>\{50,47,44,41,…\}</me>
        </p>
      </statement>
      <solution>
        <p>
          <m>a_{n}=53-3n</m>
        </p>
      </solution>
    </exercise>
  
    <exercise xml:id="PRECALC-enVQrm5zGa" original="PRECALC/modules/m49445/index.cnxml" license="CC-BY-4.0">
      <title>Try It</title>
      <statement>
        <p>Find the number of terms in the finite arithmetic sequence.</p>
        <p>
          <me>\{6\text{ , }11\text{ , }16\text{ , }...\text{ , }56\}</me>
        </p>
      </statement>
      <solution>
