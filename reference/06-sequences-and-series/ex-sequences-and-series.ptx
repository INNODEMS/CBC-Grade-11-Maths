    <exercise xml:id="PRECALC-pFYL8urQj5" original="PRECALC/modules/m49445/index.cnxml" license="CC-BY-4.0">
      <title>Try It</title>
      <statement>
        <p>Is the given sequence arithmetic? If so, find the common difference.</p>
        <p>
          <me>\{18,16,14,12,10,…\}</me>
        </p>
      </statement>
      <solution>
        <p>The sequence is arithmetic. The common difference is <m>-2.</m>
        </p>
      </solution>
    </exercise>
  
    <exercise xml:id="PRECALC-AY4DeFXnz1" original="PRECALC/modules/m49445/index.cnxml" license="CC-BY-4.0">
      <title>Try It</title>
      <statement>
        <p>Is the given sequence arithmetic? If so, find the common difference.</p>
        <p>
          <me>\{1,3,6,10,15,…\}</me>
        </p>
      </statement>
      <solution>
        <p>The sequence is not arithmetic because <m>3-1 \ne 6-3.</m>
        </p>
      </solution>
    </exercise>
  
    <exercise xml:id="PRECALC-Fl7lcpTRCB" original="PRECALC/modules/m49445/index.cnxml" license="CC-BY-4.0">
