                    <cell><m>-(1)^2+2(1)-5=-4</m></cell>
                  </row>
                  <row>
                    <cell><m>2</m></cell>
                    <cell><m>-(2)^2+2(2)-5=-5</m></cell>
                  </row>
                  <row bottom="none">
                    <cell><m>3</m></cell>
                    <cell><m>-(3)^2+2(3)-5=-8</m></cell>
                  </row>
