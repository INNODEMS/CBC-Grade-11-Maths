    <exercisegroup>
        <title>Algebraic</title>
        <introduction>
          <p>For the following exercises, solve each system by substitution.</p>
        </introduction>
        <exercise xml:id="PRECALC-eajuF0912U-parts" original="PRECALC/modules/m49420/index.cnxml" license="CC-BY-4.0">
          <statement>
            <ol marker="(a)" cols="2">
              <li>
                <md>
                  <mrow>x+3y&amp;=5</mrow>
                  <mrow>2x+3y&amp;=4</mrow>
                </md>
              </li>
              <li>
                <md>
                  <mrow>3x−2y&amp;=18</mrow>
                  <mrow>5x+10y&amp;=−10</mrow>
                </md>
              </li>
              <li>
                <md>
                  <mrow>4x+2y&amp;=−10</mrow>
                  <mrow>3x+9y&amp;=0</mrow>
                </md>
              </li>
              <li>
                <md>
                  <mrow>2x+4y&amp;=−3.8</mrow>
                  <mrow>9x−5y&amp;=1.3</mrow>
                </md>
              </li>
              <li>
                <md>
                  <mrow>-2x+3y&amp;=1.2</mrow>
                  <mrow>-3x-6y&amp;=1.8</mrow>
                </md>
              </li>
              <li>
                <md>
                  <mrow>x−0.2y&amp;=1</mrow>
                  <mrow>−10x+2y&amp;=5</mrow>
                </md>
              </li>
              <li>
                <md>
                  <mrow>3x+5y&amp;=9</mrow>
                  <mrow>30x+50y&amp;=−90</mrow>
                </md>
              </li>
              <li>
                <md>
                  <mrow>−3x+y&amp;=2</mrow>
                  <mrow>12x−4y&amp;=−8</mrow>
                </md>
              </li>
              <li>
                <md>
                  <mrow>\frac{1}{2}x+\frac{1}{3}y&amp;=16</mrow>
                  <mrow>\frac{1}{6}x+\frac{1}{4}y&amp;=9</mrow>
                </md>
              </li>
              <li>
                <md>
                  <mrow>-\frac{1}{4}x+\frac{3}{2}y&amp;=11</mrow>
                  <mrow>-\frac{1}{8}x+\frac{1}{3}y&amp;=3</mrow>
                </md>
              </li>
            </ol>
          </statement>
          <solution>
            <ol marker="(a)" cols="2">
              <li>
                <m>(−1,2)</m>
              </li>
              <li/>
              <li>
                <m>(−3,1)</m>
              </li>
              <li/>
              <li>
                <m>(-\frac{3}{5},0)</m>
              </li>
              <li/>
              <li>No solutions exist.</li>
              <li/>
              <li>
                <m>(\frac{72}{5},\frac{132}{5})</m>
              </li>
              <li/>
            </ol>
          </solution>
        </exercise>
      </exercisegroup>
  
    <exercisegroup>
        <title>Algebraic</title>
        <introduction>
          <p>For the following exercises, solve each system by addition.</p>
        </introduction>
        <exercise xml:id="PRECALC-YJJYqWRIdS-parts" original="PRECALC/modules/m49420/index.cnxml" license="CC-BY-4.0">
          <statement>
            <ol marker="(a)" cols="2">
              <li>
                <md>
                  <mrow>−2x+5y&amp;=−42</mrow>
                  <mrow>7x+2y&amp;=30</mrow>
                </md>
              </li>
              <li>
                <md>
                  <mrow>6x−5y&amp;=−34</mrow>
                  <mrow>2x+6y&amp;=4</mrow>
                </md>
              </li>
              <li>
                <md>
                  <mrow>5x-y&amp;=−2.6</mrow>
                  <mrow>−4x−6y&amp;=1.4</mrow>
                </md>
              </li>
              <li>
                <md>
                  <mrow>7x−2y&amp;=3</mrow>
                  <mrow>4x+5y&amp;=3.25</mrow>
                </md>
              </li>
              <li>
                <md>
                  <mrow>−x+2y&amp;=−1</mrow>
                  <mrow>5x−10y&amp;=6</mrow>
                </md>
              </li>
              <li>
                <md>
                  <mrow>7x+6y&amp;=2</mrow>
                  <mrow>−28x−24y&amp;=−8</mrow>
                </md>
              </li>
              <li>
                <md>
                  <mrow>\frac{5}{6}x+\frac{1}{4}y&amp;=0</mrow>
                  <mrow>\frac{1}{8}x-\frac{1}{2}y&amp;=-\frac{43}{120}</mrow>
                </md>
              </li>
              <li>
                <md>
                  <mrow>\frac{1}{3}x+\frac{1}{9}y&amp;=\frac{2}{9}</mrow>
                  <mrow>-\frac{1}{2}x+\frac{4}{5}y&amp;=-\frac{1}{3}</mrow>
                </md>
              </li>
              <li>
                <md>
                  <mrow>−0.2x+0.4y&amp;=0.6</mrow>
                  <mrow>x−2y&amp;=−3</mrow>
                </md>
              </li>
              <li>
                <md>
                  <mrow>−0.1x+0.2y&amp;=0.6</mrow>
                  <mrow>5x−10y&amp;=1</mrow>
                </md>
              </li>
            </ol>
          </statement>
          <solution>
            <ol marker="(a)" cols="2">
              <li>
                <m>(6,−6)</m>
              </li>
              <li/>
              <li>
                <m>(-\frac{1}{2},\frac{1}{10})</m>
              </li>
              <li/>
              <li>No solutions exist.</li>
              <li/>
              <li>
                <m>(-\frac{1}{5},\frac{2}{3})</m>
              </li>
              <li/>
              <li>
                <m>(x,\frac{x+3}{2})</m>
              </li>
              <li/>
            </ol>
          </solution>
        </exercise>
      </exercisegroup>
  
    <exercisegroup>
        <title>Algebraic</title>
        <introduction>
          <p>For the following exercises, solve each system by any method.</p>
        </introduction>
        <exercise xml:id="PRECALC-Y8dYJObGuY-parts" original="PRECALC/modules/m49420/index.cnxml" license="CC-BY-4.0">
          <statement>
            <ol marker="(a)" cols="2">
              <li>
                <md>
                  <mrow>5x+9y&amp;=16</mrow>
                  <mrow>x+2y&amp;=4</mrow>
                </md>
              </li>
              <li>
                <md>
                  <mrow>6x−8y&amp;=−0.6</mrow>
                  <mrow>3x+2y&amp;=0.9</mrow>
                </md>
              </li>
              <li>
                <md>
                  <mrow>5x−2y&amp;=2.25</mrow>
                  <mrow>7x−4y&amp;=3</mrow>
                </md>
              </li>
              <li>
                <md>
                  <mrow>x-\frac{5}{12}y&amp;=-\frac{55}{12}</mrow>
                  <mrow>−6x+\frac{5}{2}y&amp;=\frac{55}{2}</mrow>
                </md>
              </li>
              <li>
                <md>
                  <mrow>7x−4y&amp;=\frac{7}{6}</mrow>
                  <mrow>2x+4y&amp;=\frac{1}{3}</mrow>
                </md>
              </li>
              <li>
                <md>
                  <mrow>3x+6y&amp;=11</mrow>
                  <mrow>2x+4y&amp;=9</mrow>
                </md>
              </li>
              <li>
                <md>
                  <mrow>\frac{7}{3}x-\frac{1}{6}y&amp;=2</mrow>
                  <mrow>-\frac{21}{6}x+\frac{3}{12}y&amp;=−3</mrow>
                </md>
              </li>
              <li>
                <md>
                  <mrow>\frac{1}{2}x+\frac{1}{3}y&amp;=\frac{1}{3}</mrow>
                  <mrow>\frac{3}{2}x+\frac{1}{4}y&amp;=-\frac{1}{8}</mrow>
                </md>
              </li>
              <li>
                <md>
                  <mrow>2.2x+1.3y&amp;=−0.1</mrow>
                  <mrow>4.2x+4.2y&amp;=2.1</mrow>
                </md>
              </li>
              <li>
                <md>
                  <mrow>0.1x+0.2y&amp;=2</mrow>
                  <mrow>0.35x−0.3y&amp;=0</mrow>
                </md>
              </li>
            </ol>
          </statement>
          <solution>
            <ol marker="(a)" cols="2">
              <li>
