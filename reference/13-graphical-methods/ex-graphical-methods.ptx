    <exercisegroup xml:id="ORCCA-vvRX8cFKGM" license="CC-BY-4.0">
        <title>Graphing Quadratic Equations Using the Vertex and a Table</title>
        <exercise xml:id="ORCCA-sWEAaUNxTK" license="CC-BY-4.0">
          <statement>
            <p>
              For <m>y=4x^2-8x+5</m>, determine the vertex,
              create a table of ordered pairs,
              and then make a graph.
            </p>
          </statement>
          <solution>
            <p>
              The vertex occurs at <m>(1,1)</m>.
            </p>
  
            <sidebyside widths="47% 47%" margins="0%">
  
              <figure xml:id="ORCCA-CYp9AEm8GX" license="CC-BY-4.0">
                <caption/>
                <tabular valign="top" bottom="minor" xml:id="ORCCA-2UepP6infD" license="CC-BY-4.0">
                  <col halign="right" right="minor"/>
                  <col halign="right"/>
                  <row bottom="medium">
                    <cell><m>x</m></cell>
                    <cell halign="center"><m>y=4x^2-8x+5</m></cell>
                  </row>
                  <row>
                    <cell><m>-1</m></cell>
                    <cell><m>4(-1)^2-8(-1)+5=17</m></cell>
                  </row>
                  <row>
                    <cell><m>0</m></cell>
                    <cell><m>4(0)^2-8(0)+5=5</m></cell>
                  </row>
                  <row>
                    <cell><m>1</m></cell>
                    <cell><m>4(1)^2-8(1)+5=1</m></cell>
                  </row>
                  <row>
                    <cell><m>2</m></cell>
                    <cell><m>4(2)^2-8(2)+5=5</m></cell>
                  </row>
                  <row bottom="none">
                    <cell><m>3</m></cell>
                    <cell><m>4(3)^2-8(3)+5=17</m></cell>
                  </row>
                </tabular>
  
              </figure>
  
              <image>
  
              <latex-image>
                  
                      \begin{tikzpicture}
                          \begin{axis}[ymin=-5,ymax=20,
                                      ytick={-4,0,...,16},
                                      minor ytick={-5,-4,...,20}]
                              \addplot+[domain=-1.179:3.179] {4*x^2-8*x+5};
                              \addplot[soliddot] coordinates { (-1,17) (0,5) (1,1) (2,5) (3,17)};
                          \end{axis}
                      \end{tikzpicture}
                  
              </latex-image>
              </image>
  
            </sidebyside>
          </solution>
        </exercise>
  
        <exercise xml:id="ORCCA-AY94i6xpw4" license="CC-BY-4.0">
          <statement>
            <p>
              For <m>y=2x^2+4x+7</m>, determine the vertex,
              create a table of ordered pairs,
              and then make a graph.
            </p>
          </statement>
          <solution>
            <p>
              The vertex occurs at <m>(-1,5)</m>.
            </p>
  
            <sidebyside widths="47% 47%" margins="0%">
  
              <figure xml:id="ORCCA-aMSUFSB7Xm" license="CC-BY-4.0">
                <caption/>
                <tabular valign="top" bottom="minor" xml:id="ORCCA-1DuJVYBh4L" license="CC-BY-4.0">
                  <col halign="right" right="minor"/>
                  <col halign="right"/>
                  <row bottom="medium">
                    <cell><m>x</m></cell>
                    <cell halign="center"><m>y=2x^2+4x+7</m></cell>
                  </row>
                  <row>
                    <cell><m>-3</m></cell>
                    <cell><m>2(-3)^2+4(-3)+7=13</m></cell>
                  </row>
                  <row>
                    <cell><m>-2</m></cell>
                    <cell><m>2(-2)^2+4(-2)+7=7</m></cell>
                  </row>
                  <row>
                    <cell><m>-1</m></cell>
                    <cell><m>2(-1)^2+4(-1)+7=5</m></cell>
                  </row>
                  <row>
                    <cell><m>0</m></cell>
                    <cell><m>2(0)^2+4(0)+7=7</m></cell>
                  </row>
                  <row bottom="none">
                    <cell><m>1</m></cell>
                    <cell><m>2(1)^2+4(1)+7=13</m></cell>
                  </row>
                </tabular>
  
              </figure>
  
              <image>
  
              <latex-image>
                  
                      \begin{tikzpicture}
                          \begin{axis}[ymin=-5,ymax=20,
                                      ytick={-4,0,...,16},
                                      minor ytick={-5,-4,...,20}]
                              \addplot+[domain=-3.739:1.739] {2*x^2+4*x+7};
                              \addplot[soliddot] coordinates { (-3,13) (-2,7) (-1,5) (0,7) (1,13)};
                          \end{axis}
                      \end{tikzpicture}
                  
              </latex-image>
              </image>
  
            </sidebyside>
          </solution>
        </exercise>
  
        <exercise xml:id="ORCCA-yoBMv1VtM0" license="CC-BY-4.0">
          <statement>
            <p>
              For <m>y=-x^2+4x+2</m>, determine the vertex,
              create a table of ordered pairs,
              and then make a graph.
            </p>
          </statement>
          <solution>
            <p>
              The vertex occurs at <m>(2,6)</m>.
            </p>
  
            <sidebyside widths="47% 47%" margins="0%">
  
              <figure xml:id="ORCCA-VT3Xn1iHZc" license="CC-BY-4.0">
                <caption/>
                <tabular valign="top" bottom="minor" xml:id="ORCCA-uI42t1sDzQ" license="CC-BY-4.0">
                  <col halign="right" right="minor"/>
                  <col halign="right"/>
                  <row bottom="medium">
                    <cell><m>x</m></cell>
                    <cell halign="center"><m>y=-x^2+4x+2</m></cell>
                  </row>
                  <row>
                    <cell><m>-1</m></cell>
                    <cell><m>-(-1)^2+4(-1)+2=-3</m></cell>
                  </row>
                  <row>
                    <cell><m>0</m></cell>
                    <cell><m>-(0)^2+4(0)+2=2</m></cell>
                  </row>
                  <row>
                    <cell><m>1</m></cell>
                    <cell><m>-(1)^2+4(1)+2=5</m></cell>
                  </row>
                  <row>
                    <cell><m>2</m></cell>
                    <cell><m>-(2)^2+4(2)+2=6</m></cell>
                  </row>
                  <row>
                    <cell><m>3</m></cell>
                    <cell><m>-(3)^2+4(3)+2=5</m></cell>
                  </row>
                  <row>
                    <cell><m>4</m></cell>
                    <cell><m>-(4)^2+4(4)+2=2</m></cell>
                  </row>
                  <row bottom="none">
                    <cell><m>5</m></cell>
                    <cell><m>-(5)^2+4(5)^2+2=-3</m></cell>
                  </row>
                </tabular>
  
              </figure>
  
              <image>
  
              <latex-image>
                  
                      \begin{tikzpicture}
                          \begin{axis}[]
                              \addplot+[domain=-1.606:5.606] {-1*x^2+4*x+2};
                              \addplot[soliddot] coordinates { (-1,-3) (0,2) (1,5) (2,6) (3,5) (4,2) (5,-3)};
                          \end{axis}
                      \end{tikzpicture}
                  
              </latex-image>
              </image>
  
            </sidebyside>
          </solution>
        </exercise>
  
        <exercise xml:id="ORCCA-0mHm98Z9sE" license="CC-BY-4.0">
