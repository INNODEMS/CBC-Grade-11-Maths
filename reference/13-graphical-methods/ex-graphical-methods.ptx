        <exercise xml:id="ORCCA-eXabAYb9EJ" license="CC-BY-4.0">
          <statement>
            <p>
              For <m>y=x^2-5x+3</m>, determine the vertex,
              create a table of ordered pairs,
              and then make a graph.
            </p>
          </statement>
          <solution>
            <p>
              The vertex occurs at <m>(2.5,-3.25)</m>.
            </p>
  
            <sidebyside widths="47% 47%" margins="0%">
  
              <figure xml:id="ORCCA-5iRqaGU1to" license="CC-BY-4.0">
                <caption/>
                <tabular valign="top" bottom="minor" xml:id="ORCCA-0RvzPLfxuP" license="CC-BY-4.0">
                  <col halign="right" right="minor"/>
                  <col halign="right"/>
                  <row bottom="medium">
                    <cell><m>x</m></cell>
                    <cell halign="center"><m>y=x^2-5x+3</m></cell>
                  </row>
                  <row>
                    <cell><m>1</m></cell>
                    <cell><m>(1)^2-5(1)+3=-1</m></cell>
                  </row>
                  <row>
                    <cell><m>2</m></cell>
                    <cell><m>(2)^2-5(2)+3=-3</m></cell>
                  </row>
                  <row>
                    <cell><m>2.5</m></cell>
                    <cell><m>(2.5)^2-5(2.5)+3=-3.25</m></cell>
                  </row>
                  <row>
                    <cell><m>3</m></cell>
                    <cell><m>(3)^2-5(3)+3=-3</m></cell>
                  </row>
                  <row bottom="none">
                    <cell><m>4</m></cell>
                    <cell><m>(4)^2-5(4)+3=-1</m></cell>
                  </row>
                </tabular>
  
              </figure>
  
              <image>
  
              <latex-image>
                  
                      \begin{tikzpicture}
                          \begin{axis}[]
                              \addplot+[domain=-0.702:5.702] {x^2-5*x+3};
                              \addplot[soliddot] coordinates { (0,3) (1,-1) (2,-3) (2.5,-3.25) (3,-3) (4,-1) (5,3)};
                          \end{axis}
                      \end{tikzpicture}
                  
              </latex-image>
              </image>
  
            </sidebyside>
          </solution>
        </exercise>
  
        <exercise xml:id="ORCCA-lQUrqKpflW" license="CC-BY-4.0">
          <statement>
            <p>
              For <m>y=x^2+7x-1</m>, determine the vertex,
              create a table of ordered pairs,
              and then make a graph.
            </p>
          </statement>
          <solution>
            <p>
              The vertex occurs at <m>(-3.5,-13.25)</m>.
            </p>
  
            <sidebyside widths="47% 47%" margins="0%">
  
              <figure xml:id="ORCCA-PZbMkAcMKg" license="CC-BY-4.0">
                <caption/>
                <tabular valign="top" bottom="minor" xml:id="ORCCA-WgoSX9NX1E" license="CC-BY-4.0">
                  <col halign="right" right="minor"/>
                  <col halign="right"/>
                  <row bottom="medium">
                    <cell><m>x</m></cell>
                    <cell halign="center"><m>y=x^2+7x-1</m></cell>
                  </row>
                  <row>
                    <cell><m>-8</m></cell>
                    <cell><m>(-8)^2+7(-8)-1=7</m></cell>
                  </row>
                  <row>
                    <cell><m>-7</m></cell>
                    <cell><m>(-7)^2+7(-7)-1=-1</m></cell>
                  </row>
                  <row>
                    <cell><m>-6</m></cell>
                    <cell><m>(-6)^2+7(-6)-1=-7</m></cell>
                  </row>
                  <row>
                    <cell><m>-5</m></cell>
                    <cell><m>(-5)^2+7(-5)-1=-11</m></cell>
                  </row>
                  <row>
                    <cell><m>-4</m></cell>
                    <cell><m>(-4)^2+7(-4)-1=-13</m></cell>
                  </row>
                  <row>
                    <cell><m>-3</m></cell>
                    <cell><m>(-3)^2+7(-3)-1=-13</m></cell>
                  </row>
                  <row>
                    <cell><m>-2</m></cell>
                    <cell><m>(-2)^2+7(-2)-1=-11</m></cell>
                  </row>
                  <row>
                    <cell><m>-1</m></cell>
                    <cell><m>(-1)^2+7(-1)-1=-7</m></cell>
                  </row>
                  <row>
                    <cell><m>0</m></cell>
                    <cell><m>(0)^2+7(0)-1=-1</m></cell>
                  </row>
                  <row bottom="none">
                    <cell><m>1</m></cell>
                    <cell><m>(1)^2+7(1)-1=7</m></cell>
                  </row>
                </tabular>
  
              </figure>
  
              <image>
  
              <latex-image>
                  
                      \begin{tikzpicture}
                          \begin{axis}[xmin=-10,xmax=5,ymin=-15,ymax=10,
                                      xtick={-8,-6,...,4},
                                      minor xtick={-10,-9,...,5},
                                      ytick={-14,-12,...,8},
                                      minor ytick={-15,-14,...,10}]
                              \addplot+[domain=-8.322:1.322] {x^2+7*x-1};
                              \addplot[soliddot] coordinates { (-8,7) (-7,-1) (-6,-7) (-5,-11) (-4,-13) (-3.5,-13.25) (-3,-13) (-2,-11) (-1,-7) (0,-1) (1,7)};
                          \end{axis}
                      \end{tikzpicture}
                  
              </latex-image>
              </image>
  
            </sidebyside>
          </solution>
        </exercise>
  
        <exercise xml:id="ORCCA-TlvmrANk8v" license="CC-BY-4.0">
          <statement>
            <p>
              For <m>y=-2x^2-5x+6</m>, determine the vertex,
              create a table of ordered pairs,
              and then make a graph.
            </p>
          </statement>
          <solution>
            <p>
              The vertex occurs at <m>(-1.25,9.125)</m>.
              The axis of symmetry is used to determine points on the graph not listed in the table.
            </p>
  
            <sidebyside widths="47% 47%" margins="0%">
  
              <figure xml:id="ORCCA-Hz60cq265Q" license="CC-BY-4.0">
                <caption/>
                <tabular valign="top" bottom="minor" xml:id="ORCCA-xtsKdGjGLf" license="CC-BY-4.0">
                  <col halign="right" right="minor"/>
                  <col halign="right"/>
                  <row bottom="medium">
                    <cell><m>x</m></cell>
                    <cell halign="center"><m>y=-2x^2-5x+6</m></cell>
                  </row>
                  <row>
                    <cell><m>-3</m></cell>
                    <cell><m>-2(-3)^2-5(-3)+6=3</m></cell>
                  </row>
                  <row>
                    <cell><m>-2</m></cell>
                    <cell><m>-2(-2)^2-5(-2)+6=8</m></cell>
                  </row>
                  <row>
                    <cell><m>-1</m></cell>
                    <cell><m>-2(-1)^2-5(-1)+6=9</m></cell>
                  </row>
                  <row>
                    <cell><m>0</m></cell>
                    <cell><m>-2(0)^2-5(0)+6=6</m></cell>
                  </row>
                  <row bottom="none">
                    <cell><m>1</m></cell>
                    <cell><m>-2(1)^2-5(1)+6=-1</m></cell>
                  </row>
                </tabular>
  
              </figure>
  
              <image>
  
              <latex-image>
                  
                      \begin{tikzpicture}
                          \begin{axis}[ymin=-5,ymax=10,
                                      ytick={-4,-2,...,8},
                                      minor ytick={-4,-3,...,9}]
                              \addplot+[domain=-3.908:1.408] {-2*x^2-5*x+6};
                              \addplot[soliddot] coordinates { (-3,3) (-2,8) (-1.25,9.125) (-1,9) (0,6) (1,-1)};
                              \addplot[soliddot] coordinates { (0.5,3) (-0.5,8) (-1.5,9) (-2.5,6) (-3.5,-1)};
                          \end{axis}
                      \end{tikzpicture}
                  
              </latex-image>
              </image>
  
            </sidebyside>
          </solution>
        </exercise>
  
        <exercise xml:id="ORCCA-6qJR3GhaxP" license="CC-BY-4.0">
          <statement>
            <p>
              For <m>y=2x^2-9x</m>, determine the vertex,
              create a table of ordered pairs,
              and then make a graph.
            </p>
          </statement>
          <solution>
            <p>
              The vertex occurs at <m>(2.25,-10.125)</m>.
              The axis of symmetry is used to determine points on the graph not listed in the table.
            </p>
  
            <sidebyside widths="47% 47%" margins="0%">
  
              <figure xml:id="ORCCA-eKU0gBGFJK" license="CC-BY-4.0">
                <caption/>
                <tabular valign="top" bottom="minor" xml:id="ORCCA-TUF4pRszPw" license="CC-BY-4.0">
                  <col halign="right" right="minor"/>
                  <col halign="right"/>
                  <row bottom="medium">
                    <cell><m>x</m></cell>
                    <cell halign="center"><m>y=2x^2-9x</m></cell>
                  </row>
                  <row>
                    <cell><m>-1</m></cell>
                    <cell><m>2(-1)^2-9(-1)=11</m></cell>
                  </row>
                  <row>
                    <cell><m>-0</m></cell>
                    <cell><m>2(0)^2-9(0)=0</m></cell>
                  </row>
                  <row>
                    <cell><m>1</m></cell>
                    <cell><m>2(1)^2-9(1)=-7</m></cell>
                  </row>
                  <row>
                    <cell><m>2</m></cell>
                    <cell><m>2(2)^2-9(2)=-10</m></cell>
                  </row>
                  <row>
                    <cell><m>3</m></cell>
                    <cell><m>2(3)^2-9(3)=-9</m></cell>
                  </row>
                  <row>
                    <cell><m>4</m></cell>
                    <cell><m>2(4)^2-9(4)=-4</m></cell>
                  </row>
                  <row bottom="none">
                    <cell><m>5</m></cell>
                    <cell><m>2(5)^2-9(5)=5</m></cell>
                  </row>
                </tabular>
  
              </figure>
  
              <image>
  
              <latex-image>
                  
                      \begin{tikzpicture}
                          \begin{axis}[ymin=-15,ymax=15,
                              ytick={-12,-8,...,12},
                              minor ytick={-14,-13,...,14}]
                              \addplot+[domain=-1.294:5.794] {2*x^2-9*x};
                              \addplot[soliddot] coordinates { (-1,11) (0,0) (1,-7) (2,-10) (2.25,-10.25) (3,-9) (4,-4) (5,5)};
                              \addplot[soliddot] coordinates { (5.5,11) (4.5,0) (3.5,-7) (2.5,-10) (1.5,-9) (0.5,-4) (5,5)};
                          \end{axis}
                      \end{tikzpicture}
                  
              </latex-image>
              </image>
  
            </sidebyside>
          </solution>
        </exercise>
  
      </exercisegroup>
    <exercise><statement><p>Webwork Omitted</p></statement></exercise>
  </exercises>
  
  <!-- Borrowed from ORCCA section-graphing-quadratic-expressions: Graphing Quadratic Expressions -->
  
  <exercises>
    <title>ORCCA exercises</title>
    <exercise xml:id="ORCCA-Lp0IotvDqA" license="CC-BY-4.0">
        <statement>
          <p>
            Explain how to find a parabola's <m>y</m>-intercept when you have the equation for the parabola.
          </p>
        </statement>
      </exercise>
    <exercise xml:id="ORCCA-jBREbt89Wr" license="CC-BY-4.0">
        <statement>
          <p>
            Why does a parabola sometimes have zero <m>x</m>-intercepts, sometimes have one, and sometimes have two?
          </p>
        </statement>
      </exercise>
    <exercise xml:id="ORCCA-fi4ZSscKa9" license="CC-BY-4.0">
        <statement>
          <p>
            When you have the equation for a quadratic graph, what can you always try to use to find any horizontal intercepts?
          </p>
        </statement>
      </exercise>
    <exercise><statement><p>Webwork Omitted</p></statement></exercise>
    <exercise><statement><p>Webwork Omitted</p></statement></exercise>
    <exercisegroup cols="3" xml:id="ORCCA-BPSKw9Me8K" license="CC-BY-4.0">
        <title>Sketching Graphs of Quadratic Equations</title>
        <introduction xml:id="ORCCA-yIMqO5hXFv" license="CC-BY-4.0">
          <p>
            Graph each curve by algebraically determining its key features.
          </p>
        </introduction>
  
        <exercise xml:id="ORCCA-qYV9BzZAn7" license="CC-BY-4.0">
          <statement>
            <p>
              <m>y=x^2-7x+12</m>
            </p>
          </statement>
          <solution>
            <sidebyside widths="47% 47%" margins="0%">
  
              <stack>
                <p>
                  The parabola opens upward.
                </p>
  
                <p>
                  The <m>x</m>-intercepts are <m>(3,0)</m> and <m>(4,0)</m>.
                </p>
  
                <p>
                  The <m>y</m>-intercept is <m>(0,12)</m>.
                </p>
  
                <p>
                  The vertex is <m>(3.5,-0.25)</m> and the axis of symmetry is <m>x=3.5</m>.
                </p>
  
                <p>
                  Symmetry can be used to determine the point <m>(7,12)</m>.
                </p>
              </stack>
  
              <figure xml:id="ORCCA-0tIPQILxcP" license="CC-BY-4.0">
                <caption/>
                <image>
                  <latex-image>
                      
                          \begin{tikzpicture}
                              \begin{axis}[xmin=-10,xmax=10,ymin=-5,ymax=15,
                                  xtick={-5,0,5},minor xtick={-10,-9,...,10},
                                  ytick={0,5,10},minor ytick={-5,-4,...,15}]
                                  \addplot+[domain=-0.405:7.405] {x^2-7*x+12};
                                  \addplot[soliddot] coordinates {(3,0) (4,0) (0,12) (3.5,-0.25) (7,12)};
                              \end{axis}
                          \end{tikzpicture}
                      
                  </latex-image>
                </image>
              </figure>
            </sidebyside>
          </solution>
        </exercise>
  
        <exercise xml:id="ORCCA-34q2DmCoH2" license="CC-BY-4.0">
          <statement>
            <p>
              <m>y=x^2+5x-14</m>
            </p>
          </statement>
          <solution>
            <sidebyside widths="47% 47%" margins="0%">
  
              <stack>
                <p>
                  The parabola opens upward.
                </p>
  
                <p>
                  The <m>x</m>-intercepts are <m>(-7,0)</m> and <m>(2,0)</m>.
                </p>
  
                <p>
                  The <m>y</m>-intercept is <m>(0,-14)</m>.
                </p>
  
                <p>
                  The vertex is <m>(-2.5,-20.25)</m> and the axis of symmetry is <m>x=-2.5</m>.
                </p>
  
                <p>
                  Symmetry can be used to determine the point <m>(-5,-14)</m>.
                </p>
              </stack>
  
              <figure xml:id="ORCCA-1tQaLbEY7o" license="CC-BY-4.0">
                <caption/>
                <image>
                  <latex-image>
                      
                          \begin{tikzpicture}
                              \begin{axis}[xmin=-10,xmax=10,ymin=-25,ymax=5,
                                  xtick={-5,0,5},minor xtick={-10,-9,...,10},
                                  ytick={-20,-15,-10,-5,0},minor ytick={-25,-24,...,5}]
                                  \addplot+[domain=-7.525:2.525] {x^2+5*x-14};
                                  \addplot[soliddot] coordinates {(-7,0) (2,0) (0,-14) (-2.5,-20.25) (-5,-14)};
                              \end{axis}
                          \end{tikzpicture}
                      
                  </latex-image>
                </image>
              </figure>
            </sidebyside>
          </solution>
        </exercise>
  
        <exercise xml:id="ORCCA-KI01lh7MSU" license="CC-BY-4.0">
