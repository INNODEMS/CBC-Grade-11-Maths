                                  xtick={-5,0,5},minor xtick={-10,-9,...,10},
                                  ytick={0,5,10,15,20},minor ytick={-5,-4,...,25}]
                                  \addplot+[domain=-5.525:4.525] {-x^2-x+20};
                                  \addplot[soliddot] coordinates {(-5,0) (4,0) (0,20) (-0.5,20.25) (-1,20)};
                              \end{axis}
                          \end{tikzpicture}
                      
                  </latex-image>
                </image>
              </figure>
            </sidebyside>
          </solution>
        </exercise>
  
