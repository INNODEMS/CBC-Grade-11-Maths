    <exercisegroup>
        <title>Algebraic</title>
        <introduction>
          <p>For the following exercises, use the matrices below to perform the indicated operation if possible. If not possible, explain why the operation cannot be performed. (Hint: <m>A^{2}=A⋅A</m> )</p>
        </introduction>
        <exercise xml:id="PRECALC-JPqr75ko8P-parts" original="PRECALC/modules/m49433/index.cnxml" license="CC-BY-4.0">
          <statement>
            <ol marker="(a)" cols="2">
              <li>
                <m>AB</m>
              </li>
              <li>
                <m>BA</m>
              </li>
              <li>
                <m>CA</m>
              </li>
              <li>
                <m>BC</m>
              </li>
              <li>
                <m>A^{2}</m>
              </li>
              <li>
                <m>B^{2}</m>
              </li>
              <li>
                <m>C^{2}</m>
              </li>
              <li>
                <m>B^{2}A^{2}</m>
              </li>
              <li>
                <m>A^{2}B^{2}</m>
              </li>
              <li>
                <m>(AB)^{2}</m>
              </li>
              <li>
                <m>(BA)^{2}</m>
              </li>
            </ol>
          </statement>
          <solution>
            <ol marker="(a)" cols="2">
              <li />
              <li>
                <m>\begin{bmatrix} −350 &amp; 1,050 \\ 350 &amp; 350 \end{bmatrix}</m>
              </li>
              <li />
              <li>Undefined; inner dimensions do not match.</li>
              <li />
              <li>
                <m>\begin{bmatrix} 1,400 &amp; 700 \\ −1,400 &amp; 700 \end{bmatrix}</m>
              </li>
              <li />
              <li>
                <m>\begin{bmatrix} 332,500 &amp; 927,500 \\ −227,500 &amp; 87,500 \end{bmatrix}</m>
              </li>
              <li />
              <li>
                <m>\begin{bmatrix} 490,000 &amp; 0 \\ 0 &amp; 490,000 \end{bmatrix}</m>
              </li>
              <li />
            </ol>
          </solution>
        </exercise>
      </exercisegroup>
  
    <exercisegroup>
